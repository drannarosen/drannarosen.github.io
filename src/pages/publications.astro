---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Figure from "../components/Figure.astro";
import { cvProfile } from "../data/cv";
import { featuredPublications } from "../data/publications";
import {
  byYear,
  workUrl,
  authorLine,
  bibtex,
  publicationCount,
  firstAuthored,
  coAuthored,
  unresolvedAuthorship,
  type SyncedWork,
} from "../data/allPublications";

function authorParts(s: string): { text: string; bold: boolean }[] {
  return s.split("**").map((text, i) => ({ text, bold: i % 2 === 1 }));
}

/*
 * Link a featured paper to its astrobyte automatically, matched on the arXiv
 * URL the post already declares. Nothing here needs updating when a post is
 * added — writing the post is what creates the link.
 */
const byteFor = new Map(
  (await getCollection("astrobytes", ({ data }) => !data.draft))
    .filter((p) => p.data.paper.arxiv)
    .map((p) => [p.data.paper.arxiv!, p.id]),
);

/*
 * The bibliography is SPLIT rather than filtered: first-author vs co-authored
 * is the one division every reader wants, so making them click for it is pure
 * friction. Both groups render into the page, so find-in-page, printing and
 * JS-disabled browsing all see the complete record; the scope control below
 * only narrows what is shown, and defaults to showing everything.
 *
 * Papers whose authorship could not be resolved ride with co-authored rather
 * than being dropped — the record stays complete either way.
 */
const groups: { id: string; label: string; works: SyncedWork[] }[] = [
  { id: "first-author", label: "First-author", works: firstAuthored },
  {
    id: "co-authored",
    label: "Co-authored",
    works: [...coAuthored, ...unresolvedAuthorship],
  },
];
---

<BaseLayout
  title="Publications — Anna Rosen, Ph.D."
  description="Selected first-author publications in computational astrophysics, each with a plain-language summary: massive-star formation, feedback, star clusters, and the IMF."
  path="/publications"
  ogImage="publications.png"
  ogImageAlt="Recovered versus true IMF slope: binary-aware fits land on the one-to-one line, naive fits fall below it."
>
  <PageHeader
    eyebrow="Publications"
    title="Selected work, in plain language"
    lede={`First-author papers, each with a short summary of what it did and why it matters — followed by the full bibliography of ${publicationCount} works, synced from ORCID.`}
  />

  <div class="pubs wrap">
    {
      featuredPublications.map((p) => (
        <article class="pub">
          <p class="pub__meta">
            <span class="pub__venue">
              {p.year} · {p.venue}
            </span>
            {p.status === "submitted" && (
              <span class="pub__badge">submitted</span>
            )}
          </p>
          <h2 class="pub__title">{p.title}</h2>
          <p class="pub__authors">
            {authorParts(p.authors).map((part) =>
              part.bold ? <strong>{part.text}</strong> : part.text,
            )}
          </p>
          <p class="pub__summary prose">{p.summary}</p>
          <p class="pub__links">
            {p.arxiv && (
              <a href={p.arxiv} rel="noopener">
                arXiv ↗
              </a>
            )}
            {p.ads && (
              <a href={p.ads} rel="noopener">
                NASA ADS ↗
              </a>
            )}
            {p.arxiv && byteFor.has(p.arxiv) && (
              <a class="pub__byte" href={`/astrobytes/${byteFor.get(p.arxiv)}`}>
                Read the astrobyte →
              </a>
            )}
          </p>
          {p.figure && (
            <div class="pub__figure">
              <Figure id={p.figure.id} caption="short" contain={p.figure.contain} />
            </div>
          )}
        </article>
      ))
    }
  </div>

  <p class="pubs__note wrap">
    Longer plain-language write-ups of individual papers live in{" "}
    <a href="/astrobytes">astrobytes</a>.
    The summaries above cover selected first-author papers. The complete list
    below is synced automatically from{" "}
    <a href={cvProfile.orcid} rel="me noopener">ORCID</a>, and is also on{" "}
    <a href="https://ui.adsabs.harvard.edu/search/q=author%3A%22Rosen%2C%20Anna%22" rel="noopener">
      NASA ADS
    </a>.
  </p>

  <section class="allpubs wrap" aria-labelledby="all-pubs">
    <h2 id="all-pubs" class="allpubs__heading">
      Full bibliography <span class="allpubs__count">{publicationCount} works</span>
    </h2>

    {/* Progressive enhancement: without JS this control is absent and both
        groups simply render, which is the complete bibliography. */}
    <div class="scope" hidden data-scope-bar>
      <span class="scope__label" id="scope-label">Show</span>
      <div class="scope__opts" role="group" aria-labelledby="scope-label">
        <button type="button" class="scope__btn" data-scope="all" aria-pressed="true">
          All <span class="scope__n">{publicationCount}</span>
        </button>
        {
          groups.map((g) => (
            <button type="button" class="scope__btn" data-scope={g.id} aria-pressed="false">
              {g.label} <span class="scope__n">{g.works.length}</span>
            </button>
          ))
        }
      </div>
    </div>

    {
      groups.map((g) => (
        <div class="allpubs__group" data-group={g.id}>
          <h3 class="allpubs__grouphead">
            {g.label} <span class="allpubs__count">{g.works.length}</span>
          </h3>
          {byYear(g.works).map(({ year, works }) => (
            <div class="allpubs__year">
              <h4 class="allpubs__yr">{year}</h4>
              <ul class="allpubs__list" role="list">
                {works.map((w) => {
                  const href = workUrl(w);
                  const line = authorLine(w);
                  return (
                    <li class="allpubs__item">
                      {href ? (
                        <a href={href} rel="noopener">{w.title}</a>
                      ) : (
                        <span>{w.title}</span>
                      )}
                      {w.submittedTo && (
                        <span class="allpubs__pill">Submitted to {w.submittedTo}</span>
                      )}
                      {line && <span class="allpubs__authors">{line}</span>}
                      {w.venue && <span class="allpubs__venue">{w.venue}</span>}
                      {w.note && <span class="allpubs__note">{w.note}</span>}
                      <button
                        type="button"
                        class="allpubs__cite"
                        data-bibtex={bibtex(w)}
                        aria-label={`Copy BibTeX for ${w.title}`}
                      >
                        Cite
                      </button>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </div>
      ))
    }
  </section>

  <script>
    // Reveal the Cite buttons only where clipboard copy can actually work.
    document.documentElement.classList.add("js");
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".allpubs__cite")) {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.bibtex ?? "");
          const label = btn.textContent;
          btn.textContent = "Copied";
          btn.dataset.copied = "true";
          setTimeout(() => {
            btn.textContent = label;
            delete btn.dataset.copied;
          }, 1600);
        } catch {
          // Clipboard can be refused (permissions, insecure context). Fall back
          // to selecting the text so the reader can copy it by hand rather than
          // clicking a button that silently does nothing.
          const ta = document.createElement("textarea");
          ta.value = btn.dataset.bibtex ?? "";
          ta.style.cssText = "position:fixed;opacity:0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
          btn.textContent = "Copied";
          setTimeout(() => (btn.textContent = "Cite"), 1600);
        }
      });
    }

    // Scope control: narrows which group is visible. Revealed only once JS is
    // running, so a no-JS visitor is never shown a control that does nothing.
    const bar = document.querySelector<HTMLElement>("[data-scope-bar]");
    const groupEls = [
      ...document.querySelectorAll<HTMLElement>("[data-group]"),
    ];
    if (bar && groupEls.length > 0) {
      bar.hidden = false;
      const btns = [...bar.querySelectorAll<HTMLButtonElement>("[data-scope]")];
      for (const btn of btns) {
        btn.addEventListener("click", () => {
          const scope = btn.dataset.scope;
          for (const b of btns) {
            b.setAttribute("aria-pressed", String(b === btn));
          }
          for (const g of groupEls) {
            g.hidden = scope !== "all" && g.dataset.group !== scope;
          }
        });
      }
    }
  </script>
</BaseLayout>

<style>
  .pubs {
    display: grid;
    gap: var(--space-2xl);
    padding-block: var(--space-l) var(--space-xl);
  }
  .pub {
    padding-block-start: var(--space-l);
    border-block-start: 1px solid var(--border);
  }
  .pub__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-dim);
    margin-block-end: var(--space-2xs);
  }
  .pub__badge {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
  }
  .pub__title {
    font-size: var(--step-2);
    max-inline-size: 40ch;
    margin-block-end: var(--space-2xs);
  }
  .pub__authors {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .pub__authors strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }
  .pub__summary {
    margin-block-start: var(--space-s);
    color: var(--ink-soft);
    font-size: var(--step-1);
  }
  .pub__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    margin-block-start: var(--space-s);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .pub__byte {
    color: var(--spec-teal-bright);
  }
  .pub__figure {
    margin-block-start: var(--space-l);
  }
  .pubs__note {
    padding-block-end: var(--space-2xl);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }

  .allpubs {
    padding-block: var(--space-xl) var(--space-3xl);
    border-block-start: 1px solid var(--border);
    margin-block-start: var(--space-xl);
  }
  .allpubs__heading {
    font-size: var(--step-1);
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    flex-wrap: wrap;
  }
  .allpubs__count {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .scope {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    margin-block-start: var(--space-m);
  }
  .scope__label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .scope__opts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }
  .scope__btn {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3xs);
    padding: var(--space-3xs) var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
    background: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .scope__btn:hover {
    color: var(--ink);
    border-color: var(--border-strong);
  }
  .scope__btn[aria-pressed="true"] {
    color: var(--spec-teal-bright);
    border-color: color-mix(in srgb, var(--spec-teal-bright) 45%, transparent);
  }
  .scope__n {
    color: var(--ink-faint);
    font-size: var(--step--2);
  }

  .allpubs__group {
    margin-block-start: var(--space-l);
  }
  .allpubs__grouphead {
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    font-size: var(--step-0);
    color: var(--ink-soft);
    padding-block-end: var(--space-3xs);
    border-block-end: 1px solid var(--border);
  }

  .allpubs__year {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-s);
    margin-block-start: var(--space-m);
  }
  /* A year heading governs every entry in its group, but with only a
     two-column grid the second and later entries render beside blank space and
     read as though their year is missing. The rule ties the group together. */
  .allpubs__list {
    /* --border (9% white) is too faint to carry meaning here; this rule has a
       job to do, so it uses the stronger hairline. */
    border-inline-start: 1px solid var(--border-strong);
    padding-inline-start: var(--space-s);
  }
  /* Keeps the year in view beside a long group (2024 has six entries). */
  .allpubs__yr {
    position: sticky;
    inset-block-start: calc(var(--header-h, 3.7rem) + var(--space-2xs));
    align-self: start;
  }
  .allpubs__yr {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--spec-cyan, #4fd6c4);
    margin-block-start: 0.15em;
  }
  .allpubs__list { display: grid; gap: var(--space-xs); padding: 0; margin: 0; }
  .allpubs__item {
    font-size: var(--step-0);
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .allpubs__item a { color: var(--ink); text-decoration-color: var(--border); }
  .allpubs__item a:hover { text-decoration-color: var(--spec-cyan, #4fd6c4); }
  .allpubs__pill {
    display: inline-block;
    margin-inline-start: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 8px;
    vertical-align: 2px;
  }
  .allpubs__authors {
    display: block;
    /* Author lists are read, not glanced at — 0.72rem was 11.5px. */
    font-size: var(--step--1);
    color: var(--ink-faint);
    line-height: 1.4;
  }
  .allpubs__venue {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  /* The most-wanted affordance on any publications page, and the site had
     none. Revealed only when JS is running, since a button that cannot copy
     is worse than no button. */
  .allpubs__cite {
    display: none;
    margin-block-start: var(--space-3xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
    background: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 1px 9px;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  :global(html.js) .allpubs__cite {
    display: inline-block;
  }
  .allpubs__cite:hover {
    color: var(--spec-teal-bright);
    border-color: color-mix(in srgb, var(--spec-teal-bright) 45%, transparent);
  }
  .allpubs__cite[data-copied] {
    color: var(--spec-teal-bright);
    border-color: var(--spec-teal-bright);
  }
  .allpubs__note {
    display: block;
    margin-block-start: var(--space-3xs);
    padding-inline-start: var(--space-2xs);
    border-inline-start: 2px solid
      color-mix(in srgb, var(--spec-teal-bright) 35%, transparent);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--ink-dim);
    line-height: 1.45;
  }
  @media (max-width: 34rem) {
    .allpubs__year { grid-template-columns: 1fr; gap: var(--space-2xs); }
  }

  /* On paper the scope control is meaningless and every group should print. */
  @media print {
    .scope { display: none; }
    .allpubs__group[hidden] { display: block !important; }
  }
</style>
