---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Figure from "../components/Figure.astro";
import { cvProfile } from "../data/cv";
import { featuredPublications } from "../data/publications";
import { byYear, workUrl, publicationCount } from "../data/allPublications";

function authorParts(s: string): { text: string; bold: boolean }[] {
  return s.split("**").map((text, i) => ({ text, bold: i % 2 === 1 }));
}
---

<BaseLayout
  title="Publications — Anna Rosen, Ph.D."
  description="Selected first-author publications in computational astrophysics, each with a plain-language summary: massive-star formation, feedback, star clusters, and the IMF."
  path="/publications"
>
  <PageHeader
    eyebrow="Publications"
    title="Selected work, in plain language"
    lede={`First-author papers, each with a short summary of what it did and why it matters — followed by the full bibliography of ${publicationCount} works, synced from ORCID.`}
  />

  <div class="pubs wrap">
    {
      featuredPublications.map((p) => (
        <article class="pub">
          <p class="pub__meta">
            <span class="pub__venue">
              {p.year} · {p.venue}
            </span>
            {p.status === "submitted" && (
              <span class="pub__badge">submitted</span>
            )}
          </p>
          <h2 class="pub__title">{p.title}</h2>
          <p class="pub__authors">
            {authorParts(p.authors).map((part) =>
              part.bold ? <strong>{part.text}</strong> : part.text,
            )}
          </p>
          <p class="pub__summary prose">{p.summary}</p>
          <p class="pub__links">
            {p.arxiv && (
              <a href={p.arxiv} rel="noopener">
                arXiv ↗
              </a>
            )}
            {p.ads && (
              <a href={p.ads} rel="noopener">
                NASA ADS ↗
              </a>
            )}
          </p>
          {p.figure && (
            <div class="pub__figure">
              <Figure
                src={p.figure.src}
                alt={p.figure.alt}
                caption={p.figure.caption}
                credit={p.figure.credit}
                width={p.figure.width}
                height={p.figure.height}
                preliminary={p.figure.preliminary}
                contain={p.figure.contain}
              />
            </div>
          )}
        </article>
      ))
    }
  </div>

  <p class="pubs__note wrap">
    The summaries above cover selected first-author papers. The complete list
    below is synced automatically from{" "}
    <a href={cvProfile.orcid} rel="me noopener">ORCID</a>, and is also on{" "}
    <a href="https://ui.adsabs.harvard.edu/search/q=author%3A%22Rosen%2C%20Anna%22" rel="noopener">
      NASA ADS
    </a>.
  </p>

  <section class="allpubs wrap" aria-labelledby="all-pubs">
    <h2 id="all-pubs" class="allpubs__heading">
      Full bibliography <span class="allpubs__count">{publicationCount} works</span>
    </h2>
    {
      byYear().map(({ year, works }) => (
        <div class="allpubs__year">
          <h3 class="allpubs__yr">{year}</h3>
          <ul class="allpubs__list" role="list">
            {works.map((w) => {
              const href = workUrl(w);
              return (
                <li class="allpubs__item">
                  {href ? (
                    <a href={href} rel="noopener">{w.title}</a>
                  ) : (
                    <span>{w.title}</span>
                  )}
                  {w.venue && <span class="allpubs__venue">{w.venue}</span>}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .pubs {
    display: grid;
    gap: var(--space-2xl);
    padding-block: var(--space-l) var(--space-xl);
  }
  .pub {
    padding-block-start: var(--space-l);
    border-block-start: 1px solid var(--border);
  }
  .pub__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-dim);
    margin-block-end: var(--space-2xs);
  }
  .pub__badge {
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
  }
  .pub__title {
    font-size: var(--step-2);
    max-inline-size: 40ch;
    margin-block-end: var(--space-2xs);
  }
  .pub__authors {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .pub__authors strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }
  .pub__summary {
    margin-block-start: var(--space-s);
    color: var(--ink-soft);
    font-size: var(--step-1);
  }
  .pub__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    margin-block-start: var(--space-s);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .pub__figure {
    margin-block-start: var(--space-l);
  }
  .pubs__note {
    padding-block-end: var(--space-2xl);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }

  .allpubs {
    padding-block: var(--space-xl) var(--space-3xl);
    border-block-start: 1px solid var(--border);
    margin-block-start: var(--space-xl);
  }
  .allpubs__heading {
    font-size: var(--step-1);
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    flex-wrap: wrap;
  }
  .allpubs__count {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .allpubs__year {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-s);
    margin-block-start: var(--space-m);
  }
  .allpubs__yr {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--spec-cyan, #4fd6c4);
    margin-block-start: 0.15em;
  }
  .allpubs__list { display: grid; gap: var(--space-xs); padding: 0; margin: 0; }
  .allpubs__item {
    font-size: var(--step--1);
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .allpubs__item a { color: var(--ink); text-decoration-color: var(--border); }
  .allpubs__item a:hover { text-decoration-color: var(--spec-cyan, #4fd6c4); }
  .allpubs__venue {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--ink-dim);
  }
  @media (max-width: 34rem) {
    .allpubs__year { grid-template-columns: 1fr; gap: var(--space-2xs); }
  }
</style>
