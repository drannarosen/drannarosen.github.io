---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Not found — Anna Rosen"
  description="That page could not be found."
  path="/404"
>
  <section class="notfound wrap">
    <p class="notfound__code">404</p>
    <h1 class="notfound__title">Lost in parameter space</h1>
    <p class="notfound__lede prose">
      That page isn't here. It may have moved, or never existed in this branch
      of the tree.
    </p>
    <p><a href="/">Return to the homepage →</a></p>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding-block: var(--space-3xl);
    text-align: center;
  }
  .notfound__code {
    font-family: var(--font-mono);
    font-size: var(--step-2);
    color: var(--spec-cyan);
    letter-spacing: var(--tracking-wide);
  }
  .notfound__title {
    font-size: var(--step-4);
    margin-block: var(--space-s);
  }
  .notfound__lede {
    color: var(--ink-soft);
    margin-inline: auto;
    margin-block-end: var(--space-l);
  }
</style>
