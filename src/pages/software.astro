---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import JaxstroEcosystem from "../components/JaxstroEcosystem.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { READINESS_LABEL, READINESS_STEPS, READINESS_TOTAL } from "../data/jaxstro";
import { getPackages, packageHref } from "../lib/packages";

const packages = await getPackages();
---

<BaseLayout
  title="Software — Anna Rosen, Ph.D."
  description="Jaxstro: a JAX-native, differentiable stellar-astrophysics ecosystem spanning cluster birth, dynamics, stellar evolution, survey observables, and inference."
  path="/software"
  ogImage="software.png"
>
  {/* The opening prose claims the pipeline returns an exact sensitivity, not
      just a prediction. The evidence sits level with the claim, in the header's
      aside, rather than a click away on the fluxax page. */}
  <PageHeader
    eyebrow="Software"
    title="Differentiable astrophysics, built as instruments"
    lede="I build JAX-native scientific software where every step — from a cluster's birth to its survey observables — is a smooth, differentiable function. The pipeline returns not just a prediction, but its exact sensitivity to each physical parameter."
  >
    <p class="sw-intro__more">
      <strong>Jaxstro</strong> is the spine of that program: a family of packages
      that each own one scientific stage and remain independently useful. It powers
      current work on star-cluster identifiability, and it is built to outlast any
      single project — a foundation for questions I haven't asked yet.
    </p>

    <figure class="sw-fig" slot="aside">
      <img
        src="/images/software/fluxax-pixel-information.webp"
        alt="Six panels in two columns. Top row: a simulated g-band image of a crowded cluster, first as an expected source-limited scene and then as a nominal 30-second Rubin-like exposure with sky and noise. Middle row: maps of how much information each pixel carries about the IMF slope. Bottom row: the same for the binary mass-ratio slope. The information maps are concentrated on a sparse subset of stars, and differ between the two parameters."
        width={1466}
        height={1729}
        loading="eager"
        decoding="async"
      />
      <figcaption>
        <span class="sw-fig__chip">Preliminary</span>
        <strong>This is what differentiable codes buy you.</strong> Fisher
        information per pixel — IMF slope (middle), mass-ratio slope (bottom).
        <a href="/software/fluxax">fluxax</a>
      </figcaption>
    </figure>
  </PageHeader>

  <section class="wrap-wide sw-eco" aria-labelledby="eco-heading">
    <h2 id="eco-heading" class="sw-section-title">The Jaxstro Ecosystem</h2>
    <JaxstroEcosystem />
  </section>

  <section class="wrap sw-packages" aria-labelledby="pkg-heading">
    <h2 id="pkg-heading" class="sw-section-title">The packages</h2>

    {/* Each row links to the package's own page. The thumbnail is the hook:
        a figure earns a click in a way a paragraph does not. */}
    <ol class="pipeline" role="list">
      {
        packages.map((pkg) => {
          const d = pkg.data;
          const fig = d.figures[0];
          return (
            <li
              class:list={["pkg", d.order === 0 ? "pkg--base" : "pkg--stage"]}
              id={`pkg-${d.name}`}
            >
              <div class="pkg__rail">
                <span class="pkg__num">{String(d.order).padStart(2, "0")}</span>
                <span class="pkg__stage">{d.stage}</span>
              </div>
              <div class="pkg__body">
                <h3 class="pkg__name">
                  <a href={packageHref(pkg)}>{d.name}</a>
                </h3>
                <p class="pkg__tagline">{d.tagline}</p>
                <p class="pkg__desc">{d.description}</p>
                <div class="pkg__foot">
                  <span
                    class="meter"
                    title={d.maturity}
                    aria-label={`Readiness: ${READINESS_LABEL[d.readiness]}`}
                  >
                    {Array.from({ length: READINESS_TOTAL }, (_, k) => k + 1).map((n) => (
                      <span class:list={["meter__step", n <= READINESS_STEPS[d.readiness] && "is-on"]} />
                    ))}
                    <span class="meter__label">{READINESS_LABEL[d.readiness]}</span>
                  </span>
                  {d.maturity && d.maturity !== READINESS_LABEL[d.readiness] && (
                    <span class="pkg__note">{d.maturity}</span>
                  )}
                </div>
              </div>

              <a class="pkg__thumb" href={packageHref(pkg)} tabindex="-1" aria-hidden="true">
                {fig ? (
                  <img src={fig.src} alt="" width={fig.width} height={fig.height} loading="lazy" decoding="async" />
                ) : (
                  <span class="pkg__thumb-empty" />
                )}
              </a>
            </li>
          );
        })
      }
    </ol>

    <p class="sw-note prose">
      No package is publicly released yet; methods papers come first. The
      readiness meter is the honest signal — everything here is under active
      development, and they differ in how far along they are. Each package has
      its own page with the demos that show it working, and what its methods
      paper will establish.
    </p>
  </section>
</BaseLayout>

<style>
  .sw-intro__more {
    color: var(--ink-soft);
    margin-block-start: var(--space-m);
  }
  .sw-intro__more strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }

  /* The figure occupies the header's aside column, so it is sized by the grid
     rather than by a float. */
  .sw-fig {
    margin: 0;
  }
  .sw-fig img {
    inline-size: 100%;
    block-size: auto;
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    background: var(--bg-deep);
  }
  .sw-fig figcaption {
    margin-block-start: var(--space-2xs);
    font-size: var(--step--2);
    line-height: 1.5;
    color: var(--ink-dim);
  }
  .sw-fig figcaption strong {
    color: var(--ink-soft);
    font-weight: 600;
  }
  .sw-fig__chip {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 0 6px;
    margin-inline-end: 0.25em;
  }
  /* Stacked (below the header's split breakpoint): centre it rather than
     letting a portrait run the full content width. */
  @media (max-width: 60rem) {
    .sw-fig {
      inline-size: min(100%, 20rem);
      margin-inline: auto;
    }
  }

  .sw-section-title {
    font-size: var(--step-2);
    margin-block-end: var(--space-m);
  }


  .sw-eco {
    padding-block-end: var(--space-2xl);
  }

  /* A staged chain, not a card grid: the foundation sits apart and the five
     pipeline stages read top-to-bottom in flow order. */
  .pkg {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr) 13rem;
    gap: var(--space-m) var(--space-l);
    align-items: start;
    padding-block: var(--space-m);
    /* Anchor targets (/software#pkg-gravax) must clear the sticky header.
       --header-h is published by SiteHeader on every page. */
    scroll-margin-block-start: calc(var(--header-h, 3.7rem) + var(--space-m));
  }
  /* 00 is the substrate, not a step. */
  .pkg--base .pkg__num {
    color: var(--ink-faint);
  }

  .pipeline {
    display: grid;
    margin: 0;
    padding: 0;
    counter-reset: stage;
  }
  /* The connecting rule down the rail is the pipeline made visible. */
  .pkg--stage {
    border-block-start: 1px solid var(--border);
  }

  .pkg__rail {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }
  .pkg__num {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--spec-teal-bright);
  }
  .pkg__stage {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-dim);
    line-height: 1.4;
  }

  .pkg__name {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--spec-teal-bright);
  }
  .pkg__name a {
    color: inherit;
    text-decoration: none;
  }
  .pkg__name a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .pkg__tagline {
    color: var(--ink);
    font-size: var(--step-0);
    margin-block: var(--space-3xs) var(--space-2xs);
  }
  .pkg__desc {
    color: var(--ink-soft);
    /* Was --step--1 (15px). This is the paragraph that explains the package —
       body copy, not a caption, so it gets body size. */
    font-size: var(--step-0);
    max-inline-size: 62ch;
    line-height: 1.6;
  }
  .pkg__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2xs) var(--space-m);
    margin-block-start: var(--space-s);
  }
  .pkg__note {
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .pkg__link {
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  /* The thumbnail is the hook. Presentational only: the row's heading link is
     the real target, so this one is aria-hidden and out of the tab order
     rather than a second identical link for a screen reader to announce. */
  .pkg__thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xs);
    border-radius: var(--radius-s);
    overflow: hidden;
    background: #fff;
    box-shadow: 0 0 0 1px var(--border);
    transition: box-shadow var(--dur-base) var(--ease-out);
  }
  /* Fit, never crop: these are plots, and cropping one can remove the axis
     that makes it readable. Heights differ by figure, capped so no row grows
     taller than its text. */
  .pkg__thumb img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    max-block-size: 7.5rem;
    object-fit: contain;
  }
  .pkg:hover .pkg__thumb {
    box-shadow: 0 0 0 1px var(--spec-teal-bright);
  }
  .pkg__thumb-empty {
    display: block;
    aspect-ratio: 16 / 10;
    background: var(--bg-surface);
  }

  /* Readiness is what actually differs between packages; status does not. */
  .meter {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }
  .meter__step {
    inline-size: 14px;
    block-size: 3px;
    border-radius: 2px;
    background: var(--bg-surface);
    box-shadow: inset 0 0 0 1px var(--border);
  }
  .meter__step.is-on {
    background: var(--spec-teal-bright);
    box-shadow: none;
  }
  .meter__label {
    margin-inline-start: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-dim);
  }

  @media (max-width: 60rem) {
    .pkg {
      grid-template-columns: 5rem minmax(0, 1fr);
    }
    .pkg__thumb {
      grid-column: 1 / -1;
      max-inline-size: 22rem;
    }
  }
  @media (max-width: 46rem) {
    .pkg {
      grid-template-columns: 1fr;
      gap: var(--space-2xs);
    }
    .pkg__rail {
      flex-direction: row;
      align-items: baseline;
      gap: var(--space-2xs);
    }
  }

  .sw-note {
    margin-block-start: var(--space-xl);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }
  .sw-note strong {
    color: var(--ink-soft);
    font-weight: 600;
  }
</style>
