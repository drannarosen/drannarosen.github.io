---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import JaxstroEcosystem from "../components/JaxstroEcosystem.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { allPackages } from "../data/jaxstro";
---

<BaseLayout
  title="Software — Anna Rosen, Ph.D."
  description="JAXSTRO: a JAX-native, differentiable stellar-astrophysics ecosystem spanning cluster birth, dynamics, stellar evolution, survey observables, and inference."
  path="/software"
>
  <PageHeader
    eyebrow="Software"
    title="Differentiable astrophysics, built as instruments"
    lede="I build JAX-native scientific software where every step — from a cluster's birth to its survey observables — is a smooth, differentiable function. The pipeline returns not just a prediction, but its exact sensitivity to each physical parameter."
  />

  <section class="wrap sw-intro">
    <p class="prose">
      <strong>JAXSTRO</strong> is the spine of that program: a family of packages
      that each own one scientific stage and remain independently useful. It powers
      current work on star-cluster identifiability, and it is built to outlast any
      single project — a foundation for questions I haven't asked yet.
    </p>
  </section>

  <section class="wrap-wide sw-eco" aria-labelledby="eco-heading">
    <h2 id="eco-heading" class="sw-section-title">The ecosystem</h2>
    <JaxstroEcosystem />
  </section>

  <section class="wrap sw-packages" aria-labelledby="pkg-heading">
    <h2 id="pkg-heading" class="sw-section-title">The packages</h2>
    <ul class="sw-cards" role="list">
      {
        allPackages.map((pkg) => (
          <li class="sw-card" id={`pkg-${pkg.name}`}>
            <div class="sw-card__head">
              <h3 class="sw-card__name">{pkg.name}</h3>
              <StatusBadge status={pkg.status} />
            </div>
            <p class="sw-card__stage">
              {pkg.stage}
              {pkg.maturity && <span class="sw-card__maturity"> · {pkg.maturity}</span>}
            </p>
            <p class="sw-card__desc">{pkg.description}</p>
            {(pkg.repo || pkg.docs) && (
              <p class="sw-card__links">
                {pkg.repo && <a href={pkg.repo} rel="noopener">Repository ↗</a>}
                {pkg.docs && (
                  <a href={pkg.docs} rel="noopener">Preview docs ↗</a>
                )}
              </p>
            )}
          </li>
        ))
      }
    </ul>
    <p class="sw-note prose">
      Every package is an <strong>active build</strong> — validated in
      substantial part and advancing, but not yet publicly released; methods
      papers come first. The maturity note on each indicates how far along it
      is. <strong>Preview documentation</strong> is shared for
      <code>jaxstro</code> and <code>progenax</code> to show the direction of
      the work; the source and full API will be released with each package's
      methods paper.
    </p>
  </section>
</BaseLayout>

<style>
  .sw-intro {
    padding-block-end: var(--space-xl);
  }
  .sw-intro .prose {
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .sw-intro strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }

  .sw-section-title {
    font-size: var(--step-2);
    margin-block-end: var(--space-m);
  }

  .sw-eco {
    padding-block-end: var(--space-2xl);
  }

  .sw-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: var(--space-m);
  }
  .sw-card {
    padding: var(--space-m);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    scroll-margin-block-start: var(--space-xl);
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .sw-card:target,
  .sw-card:hover {
    border-color: color-mix(in srgb, var(--spec-teal) 40%, var(--border));
  }
  .sw-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    margin-block-end: var(--space-3xs);
  }
  .sw-card__name {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--spec-teal-bright);
  }
  .sw-card__stage {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-block-end: var(--space-2xs);
  }
  .sw-card__maturity {
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-faint);
  }
  .sw-card__desc {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .sw-card__links {
    margin-block-start: var(--space-s);
    display: flex;
    gap: var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .sw-note {
    margin-block-start: var(--space-xl);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }
  .sw-note strong {
    color: var(--ink-soft);
    font-weight: 600;
  }
</style>
