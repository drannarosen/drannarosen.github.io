---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<BaseLayout
  title="Star-render lab — Anna Rosen"
  description="Internal prototype: a photographic observed-mode star-cluster renderer on the real gravoturb cluster."
  path="/star-render-lab"
  noindex
>
  <PageHeader
    eyebrow="Prototype · not linked"
    title="Star-render lab"
    lede="A testbed for the photographic star renderer: apparent flux from each star's own luminosity, robust asinh exposure, a bounded unresolved core with a Moffat PSF, and restrained HDR glare. The physics lives in pure, dependency-free novascope modules; this page is the Three.js harness around them. Currently showing a backend smoke test — instanced quads through WebGPU, or WebGL 2 with ?forceWebGL — not yet the cluster."
  />

  <div class="srl wrap-wide">
    <div class="srl__stage">
      <canvas class="srl__canvas" data-stage aria-label="A star cluster rendered in observed mode."></canvas>
      <p class="srl__status" data-status aria-live="polite">Loading…</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { initStarLab } from "../lib/starlab/scene";

  const canvas = document.querySelector<HTMLCanvasElement>("[data-stage]");
  const status = document.querySelector<HTMLElement>("[data-status]");
  const setStatus = (t: string) => {
    if (status) status.textContent = t;
  };

  // ?forceWebGL exercises the WebGPURenderer's WebGL 2 fallback on a machine
  // that would otherwise always take the native path. Development affordance:
  // ~5% of visitors get that backend, so it needs to be checkable on demand.
  const forceWebGL = new URLSearchParams(location.search).has("forceWebGL");

  if (canvas) {
    initStarLab(canvas, { forceWebGL })
      .then((lab) => {
        const label = lab.backend === "webgpu" ? "WebGPU" : "WebGL 2";
        setStatus(`${label}${forceWebGL ? " (forced)" : ""} · ${lab.starCount} test quads`);
        // Expose the live backend for verification without a screenshot.
        (window as unknown as { starlab?: unknown }).starlab = { backend: lab.backend };
      })
      .catch((err: unknown) => {
        setStatus(`Failed: ${String(err)}`);
      });
  }
</script>

<style>
  .srl { padding-block: var(--space-l) var(--space-3xl); display: grid; gap: var(--space-m); }
  .srl__stage { position: relative; aspect-ratio: 1 / 1; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: #05060a; }
  .srl__canvas { inline-size: 100%; block-size: 100%; display: block; }
  .srl__status { position: absolute; inset-block-end: 0.5rem; inset-inline-start: 0.6rem; margin: 0; font-family: var(--font-mono); font-size: var(--step--3, 0.68rem); color: var(--ink-faint); } /* type-scale-exempt: overlay status */
</style>
