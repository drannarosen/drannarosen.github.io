---
/*
 * /now — what I'm working on at the moment.
 *
 * A `now` page is a dated snapshot, not a changelog: it is allowed to go stale,
 * as long as the date says so. `updated` is rendered prominently for exactly
 * that reason — a page claiming to be current with no date is worse than one
 * openly six months old.
 *
 * The previous version was derived ENTIRELY from data files. That kept it
 * consistent with the rest of the site and, by the same stroke, kept it from
 * saying anything the rest of the site did not: derived data reports what
 * exists, never what matters, and a /now page is entirely about what matters.
 * So the prose leads and the data supports it.
 *
 * Teaching is the one section that must be computed, because it is the one
 * that can go false on its own. It previously showed courses.slice(0, 2) —
 * array order, not the calendar — and so announced two semesters that had
 * already ended. See src/data/teaching.ts.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ReadinessMeter from "../components/ReadinessMeter.astro";
import { getPackages } from "../lib/packages";
import { featuredPublications } from "../data/publications";
import { graduateAdvisees, finishingAdvisees } from "../data/cv";
import { nowFigures } from "../data/nowFigures";
import { renderCaption } from "../lib/figureCaption";
import { getFigure, figureSrc, figureCaption, figureBox } from "../lib/figures";
import {
  courses,
  courseWhen,
  coursesNow,
  nextCourse,
  seasonOf,
  termLabel,
  learningResources,
} from "../data/teaching";

const updated = new Date("2026-07-21");
const now = updated;

const packages = await getPackages();
const byId = new Map(packages.map((p) => [p.id, p]));
const pick = (ids: string[]) => ids.map((id) => byId.get(id)).filter((p) => p != null);
const focus = pick(["gravax", "startrax"]);
const simmering = pick(["fluxax", "informax"]);

const underReview = featuredPublications.filter((p) => p.status === "submitted");

const teachingNow = coursesNow(courses, now);
const upNext = nextCourse(courses, now);
// Summer is not a teaching term, so it needs its own sentence rather than
// "no courses this term" — there is no term for it to be true of.
const isSummer = seasonOf(now) === "summer";

// Straight from the CV record, so closing a student out there removes them
// here in the same edit rather than leaving /now announcing an old defence.
const finishing = finishingAdvisees(graduateAdvisees);
const finishingWhen = [...new Set(finishing.map((a) => a.finishing))].join(" and ");

/*
 * Resolve each strip entry against the package frontmatter that describes it,
 * so alt text, dimensions and caption have exactly one home. An unresolvable
 * reference throws rather than quietly rendering a shorter strip — a figure
 * silently missing from a gallery is indistinguishable from one never added.
 */
const strip = nowFigures.map((entry) => {
  const pkg = byId.get(entry.package);
  if (!pkg) {
    throw new Error(`[nowFigures] unknown package "${entry.package}" for ${entry.id}.`);
  }
  // getFigure throws on an unknown id, so a typo fails the build rather than
  // shipping a hole in the strip.
  return { ...entry, figure: getFigure(entry.id), pkg };
});

const fmtShort = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

const hobby = ["Sophie", "Cosmic Playground"]
  .map((name) => learningResources.find((r) => r.name === name))
  .filter((r) => r != null);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout
  title="Now — Anna Rosen, Ph.D."
  description="What I'm actually working on at the moment: the paper I'm writing, the packages taking most of my attention, and what I'm building for fun."
  path="/now"
>
  <PageHeader
    eyebrow="Now"
    title="What I'm working on"
    lede="A snapshot rather than a record. If the date below is old, so is this page."
  />

  <section class="wrap">
    <div class="now">
      <p class="now__stamp">Updated {fmt(updated)}</p>

      {/*
        The sky over San Diego, computed from the reader's clock. The fallback
        text is true on its own, so a JS-off reader gets a sentence rather than
        an empty line; the script replaces it with the live version.
      */}
      <p class="now__sky" id="sky">The work happens in San Diego, at 32.8° N.</p>

      {
        strip.length > 0 && (
          <>
            <h2 class="now__h2">Plot of the moment</h2>
            {/*
              A scroll-snap strip: swipe on touch, arrow keys on the focused
              region, and the numbered anchors below for a pointer. No
              JavaScript and no carousel library — with JS off it degrades to
              a scrollable row of figures, which is still the whole content.
            */}
            <div class="strip" tabindex="0" role="region" aria-label="Recent figures">
              {strip.map((s, i) => (
                <figure class="strip__item" id={`plot-${i + 1}`}>
                  <img
                    class="figure-box"
                    style={figureBox(s.figure)}
                    src={figureSrc(s.figure)}
                    alt={s.figure.alt}
                    width={s.figure.width}
                    height={s.figure.height}
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                  <figcaption>
                    <span class="strip__date">{fmtShort(s.added)}</span>
                    <strong class="strip__title">{s.figure.title}.</strong>{" "}
                    <span set:html={renderCaption(figureCaption(s.figure, "short"))} />{" "}
                    <a href={`/software/${s.pkg.id}`}>{s.pkg.data.name} →</a>
                  </figcaption>
                </figure>
              ))}
            </div>
            <nav class="strip__nav" aria-label="Choose a figure">
              {strip.map((s, i) => (
                <a href={`#plot-${i + 1}`} aria-label={`Figure ${i + 1}: ${s.figure.title}`}>
                  {i + 1}
                </a>
              ))}
            </nav>
          </>
        )
      }

      <h2 class="now__h2">On my desk</h2>
      <div class="prose flow">
        <p>
          I'm writing the <a href="/software/progenax">progenax</a> methods paper,
          and I expect it out later this summer.
        </p>
        {
          underReview.map((p) => (
            <p>
              <span class="now__title">{p.title}</span> is under review at {p.venue}
              {p.reviewNote && <> — {p.reviewNote}</>}
              {p.arxiv && (
                <>
                  {". "}
                  <a href={p.arxiv} rel="noopener">
                    Read it on arXiv
                  </a>
                </>
              )}
              .
            </p>
          ))
        }
      </div>

      {
        finishing.length > 0 && (
          <>
            <h2 class="now__h2">Nearly out the door</h2>
            <div class="prose flow">
              <p>
                {finishing.length === 2 ? "Two" : finishing.length} masters students
                are finishing in {finishingWhen}.
              </p>
            </div>
            <ul class="now__list" role="list">
              {finishing.map((a) => (
                <li>
                  <span class="now__name">{a.name}</span>
                  {a.program && <span class="now__meta">{a.program}</span>}
                  {a.project && <span class="now__meta">{a.project}</span>}
                </li>
              ))}
            </ul>
          </>
        )
      }

      <h2 class="now__h2">Where the interesting problems are</h2>
      <div class="prose flow">
        <p>
          {/* Explicit {" "} — Astro collapses the newline after a closing tag,
              which silently produced "startraxare taking". */}
          <a href="/software/gravax">gravax</a> and <a href="/software/startrax">startrax</a>{" "}
          are taking most of the development effort.
        </p>
      </div>
      <ul class="now__list" role="list">
        {
          focus.map((p) => (
            <li>
              <a class="now__name" href={`/software/${p.id}`}>
                {p.data.name}
              </a>
              <span class="now__meta">{p.data.tagline}</span>
              <ReadinessMeter readiness={p.data.readiness} title={p.data.maturity} />
            </li>
          ))
        }
      </ul>

      <h2 class="now__h2">Simmering</h2>
      <ul class="now__list now__list--quiet" role="list">
        {
          simmering.map((p) => (
            <li>
              <a class="now__name" href={`/software/${p.id}`}>
                {p.data.name}
              </a>
              <span class="now__meta">{p.data.tagline}</span>
              <ReadinessMeter readiness={p.data.readiness} title={p.data.maturity} />
            </li>
          ))
        }
      </ul>

      <h2 class="now__h2">Teaching</h2>
      <div class="prose flow">
        {
          teachingNow.length > 0 ? (
            <ul class="now__list" role="list">
              {teachingNow.map((c) => (
                <li>
                  <span class="now__name">
                    {c.code} — {c.title}
                  </span>
                  <span class="now__meta">{courseWhen(c)}</span>
                </li>
              ))}
            </ul>
          ) : isSummer ? (
            <p>It's summer — no classes, and the research runs at full tilt.</p>
          ) : (
            <p>No courses this term.</p>
          )
        }
        {
          upNext && (
            <p>
              Next up: {upNext.course.code} — {upNext.course.title}, {termLabel([upNext.term])}.
            </p>
          )
        }
        <p class="now__aside">
          Everything I've taught is on the <a href="/teaching">teaching page</a>.
        </p>
      </div>

      <h2 class="now__h2">Side projects</h2>
      <ul class="now__list" role="list">
        {
          hobby.map((r) => (
            <li>
              <a class="now__name" href={r.url} rel="noopener">
                {r.name}
              </a>
              <span class="now__meta">{r.blurb}</span>
            </li>
          ))
        }
      </ul>

      <p class="now__note">
        Inspired by <a href="https://nownownow.com/about" rel="noopener">nownownow.com</a>.
        Longer-form writing is in <a href="/astrobytes">astrobytes</a>; the full record is
        on the <a href="/cv">CV</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  import { sunPosition, hoursUntilDusk } from "../lib/sunSanDiego";

  const el = document.getElementById("sky");
  if (el) {
    const now = new Date();
    const { altitudeDeg } = sunPosition(now);
    const alt = Math.round(altitudeDeg);

    const until = (target: number) => {
      const h = hoursUntilDusk(now, target);
      if (h == null) return null;
      const mins = Math.round(h * 60);
      return mins < 60 ? `${mins} min` : `${Math.floor(mins / 60)} h ${mins % 60} min`;
    };

    let text: string;
    if (alt > 0) {
      const dusk = until(-18);
      text =
        `Over San Diego right now the Sun sits ${alt}° above the horizon` +
        (dusk ? `; astronomical twilight ends in ${dusk}.` : ".");
    } else if (altitudeDeg <= -18) {
      text = `Over San Diego right now the Sun is ${Math.abs(alt)}° below the horizon — astronomical dark.`;
    } else {
      const dusk = until(-18);
      text =
        `Over San Diego right now the Sun is ${Math.abs(alt)}° below the horizon` +
        (dusk ? `; astronomical dark in ${dusk}.` : ".");
    }
    el.textContent = text;
  }

  /*
   * Trim the figure strip to the slide actually on show.
   *
   * A flex row is as tall as its tallest child, so with figures ranging from
   * 0.33 to 1.18 in aspect ratio, and captions of different lengths, every
   * slide inherited the height of the worst case and short figures sat in a
   * large empty box. CSS alone cannot express "as tall as the visible child",
   * so this is a genuine enhancement rather than something worked around:
   * with the script absent the strip simply keeps its natural height and all
   * the content is still there and still scrollable.
   */
  const strip = document.querySelector<HTMLElement>(".strip");
  if (strip) {
    const items = [...strip.querySelectorAll<HTMLElement>(".strip__item")];

    const fit = () => {
      const edge = strip.getBoundingClientRect().left;
      let nearest = items[0];
      let best = Infinity;
      for (const item of items) {
        const d = Math.abs(item.getBoundingClientRect().left - edge);
        if (d < best) {
          best = d;
          nearest = item;
        }
      }
      if (nearest) strip.style.blockSize = `${nearest.offsetHeight}px`;
    };

    let queued = false;
    const schedule = () => {
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => {
        queued = false;
        fit();
      });
    };

    strip.addEventListener("scroll", schedule, { passive: true });
    window.addEventListener("resize", schedule);
    // Images arrive after first paint and change the heights they are measured
    // from, so re-fit once each has decoded.
    for (const img of strip.querySelectorAll("img")) {
      if (!img.complete) img.addEventListener("load", schedule, { once: true });
    }
    fit();
  }
</script>

<style>
  /*
   * The measure cap lives HERE, on an inner block — never on the .wrap, which
   * centres with margin-inline: auto and would re-centre the narrowed column so
   * its text stopped aligning with the headings above. Third time this has come
   * up; see the vertical-rhythm note in AGENTS.md.
   */
  .now {
    max-inline-size: var(--width-prose);
    padding-block-end: var(--space-3xl);
  }
  .now__stamp {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .now__h2 {
    font-size: var(--step-1);
    margin-block: var(--space-xl) var(--space-s);
    padding-block-end: var(--space-2xs);
    border-block-end: 1px solid var(--border);
  }
  .now__list {
    display: grid;
    gap: var(--space-m);
    margin-block-start: var(--space-m);
  }
  .now__name {
    display: block;
    color: var(--ink);
    font-weight: 600;
  }
  a.now__name {
    font-family: var(--font-mono);
    color: var(--spec-teal-bright);
    font-weight: 400;
  }
  .now__title {
    color: var(--ink);
    font-weight: 600;
  }
  .now__meta {
    display: block;
    margin-block-start: var(--space-3xs);
    margin-block-end: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--ink-dim);
  }
  /* Real, and not where the attention is. Said by weight rather than by a
     sentence explaining it. */
  .now__list--quiet .now__name {
    font-weight: 400;
  }
  .now__list--quiet .now__meta {
    color: var(--ink-faint);
  }
  .now__sky {
    margin-block-start: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--ink-dim);
  }
  /* One figure per slide, snapped. flex-basis 100% of the strip, not of the
     page, so the figure width follows the measure like everything else. */
  .strip {
    display: flex;
    /* Items must not stretch to the container once the script sets its height. */
    align-items: flex-start;
    gap: var(--space-m);
    transition: block-size var(--motion-med, 220ms) ease;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    margin-block-start: var(--space-m);
    /* Keeps the scrollbar off the image edge. */
    padding-block-end: var(--space-2xs);
  }
  .strip:focus-visible {
    outline: 2px solid var(--spec-teal-bright);
    outline-offset: 4px;
  }
  .strip__item {
    flex: 0 0 100%;
    scroll-snap-align: start;
    min-inline-size: 0;
  }
  /* Sizing comes from .figure-box in figures.css, which is shared with every
     other figure on the site. Only the framing is local. */
  .strip__item img {
    background: #fff;
    padding: var(--space-3xs);
    border-radius: var(--radius-m);
    box-shadow:
      0 0 0 1px var(--border-strong),
      0 18px 40px -24px rgb(0 0 0 / 0.9);
  }
  .strip__item figcaption {
    margin-block-start: var(--space-2xs);
    font-size: var(--step--1);
    line-height: 1.6;
    color: var(--ink-dim);
  }
  .strip__date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .strip__title {
    color: var(--ink);
    font-weight: 600;
  }
  .strip__nav {
    display: flex;
    gap: var(--space-2xs);
    margin-block-start: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
  }
  .strip__nav a {
    padding: 2px 9px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--ink-dim);
    text-decoration: none;
  }
  .strip__nav a:hover,
  .strip__nav a:focus-visible {
    color: var(--ink);
    border-color: var(--spec-teal-bright);
  }
  /* Snapping and smooth scrolling are motion; honour the setting. */
  @media (prefers-reduced-motion: reduce) {
    .strip {
      scroll-behavior: auto;
      scroll-snap-type: none;
      transition: none;
    }
  }

  .now__aside,
  .now__note {
    font-size: var(--step--1);
    color: var(--ink-dim);
  }
  .now__note {
    margin-block-start: var(--space-2xl);
  }
</style>
