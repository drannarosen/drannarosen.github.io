---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionNav from "../components/SectionNav.astro";
import { slugify } from "../lib/slug";
import { publicationCount } from "../data/allPublications";
import { courses } from "../data/teaching";
import { STATUS_LABEL } from "../data/jaxstro";
import { getPackages } from "../lib/packages";
import {
  cvProfile,
  employment,
  education,
  awards,
  selectedPublications,
  grants,
  grantTotalPI,
  graduateAdvisees,
  undergraduateAdvisees,
  serviceSDSU,
  serviceNational,
  serviceEarlier,
  selectedTalks,
  talkCounts,
  outreach,
  professionalDevelopment,
  type DatedEntry,
  type Advisee,
} from "../data/cv";

// Render an author string with Anna's name (wrapped in **…**) emphasized.
function authorParts(s: string): { text: string; bold: boolean }[] {
  return s.split("**").map((text, i) => ({ text, bold: i % 2 === 1 }));
}

/*
 * Section order follows standard faculty-CV convention: appointments and
 * education, then funded/recognized work, then scholarly output, then
 * teaching/service/outreach, then software. Sections whose data is empty are
 * dropped rather than rendered as empty headings — the CV only ever claims
 * what src/data actually contains.
 *
 * Teaching and Software reuse the /teaching and /software data sources so the
 * CV can never disagree with those pages.
 */
type CvSection =
  | { kind: "dated"; title: string; nav: string; entries: DatedEntry[]; lede?: string }
  | { kind: "pubs"; title: string; nav: string }
  | { kind: "grants"; title: string; nav: string }
  | { kind: "advising"; title: string; nav: string };

/* Course sites are public and are the best evidence a teaching line has, so the
   CV links them rather than naming a course and stopping there. The Typst CV
   already did; this keeps the two from disagreeing. */
const teachingEntries: DatedEntry[] = courses.map((c) => ({
  role: `${c.code} — ${c.title}`,
  date: c.when,
  roleHref: c.url ?? undefined,
}));

const softwareEntries: DatedEntry[] = (await getPackages()).map((p) => ({
  role: p.data.name,
  org: p.data.tagline,
  date: STATUS_LABEL[p.data.status],
  note: p.data.maturity,
  href: `/software/${p.id}`,
}));

const sections: CvSection[] = (
  [
    { kind: "dated", title: "Appointments", nav: "Appointments", entries: employment },
    { kind: "dated", title: "Education", nav: "Education", entries: education },
    { kind: "grants", title: "Grants & Funded Proposals", nav: "Grants" },
    { kind: "dated", title: "Awards & Honors", nav: "Awards", entries: awards },
    { kind: "pubs", title: "Selected Publications", nav: "Publications" },
    {
      kind: "dated",
      title: "Invited Talks",
      nav: "Talks",
      entries: selectedTalks,
      lede: `${talkCounts.invited} invited and ${talkCounts.contributed} contributed talks to date. A selection:`,
    },
    { kind: "dated", title: "Teaching", nav: "Teaching", entries: teachingEntries },
    { kind: "advising", title: "Advising & Mentoring", nav: "Advising" },
    { kind: "dated", title: "Service — San Diego State", nav: "Service · SDSU", entries: serviceSDSU },
    { kind: "dated", title: "Service — National & International", nav: "Service · National", entries: serviceNational },
    { kind: "dated", title: "Service — Earlier", nav: "Service · Earlier", entries: serviceEarlier },
    { kind: "dated", title: "Public Outreach", nav: "Outreach", entries: outreach },
    { kind: "dated", title: "Professional Development", nav: "Development", entries: professionalDevelopment },
    { kind: "dated", title: "Software", nav: "Software", entries: softwareEntries },
  ] satisfies CvSection[]
).filter((s) => s.kind !== "dated" || s.entries.length > 0);

const navItems = sections.map((s) => ({ id: slugify(s.title), label: s.nav }));
---

<BaseLayout
  title="CV — Anna Rosen, Ph.D."
  description="Curriculum vitae of Anna Rosen: appointments, education, awards, and selected publications in computational astrophysics."
  path="/cv"
>
  <PageHeader eyebrow="Curriculum Vitae" title="Curriculum Vitae">
  </PageHeader>

  <SectionNav items={navItems} label="CV sections" />

  <section class="wrap cv-top">
    <ul class="cv-stats" role="list">
      {
        cvProfile.stats.map((s) => (
          <li class="cv-stat">
            <span class="cv-stat__value">{s.value}</span>
            <span class="cv-stat__label">{s.label}</span>
          </li>
        ))
      }
    </ul>
    <p class="cv-actions">
      {
        cvProfile.pdf && (
          <>
            {/* Two affordances, because they are different intents: `download`
                forces a save, which browsers otherwise would not do for a PDF
                they can render inline, and the second opens it to read. */}
            <a class="cv-btn" href={cvProfile.pdf} download>
              Download CV (PDF)
            </a>
            <a class="cv-btn" href={cvProfile.pdf} target="_blank" rel="noopener">
              Open CV in new tab ↗
            </a>
          </>
        )
      }
      <a class="cv-btn" href={cvProfile.orcid} rel="me noopener">ORCID</a>
    </p>
  </section>

  {
    sections.map((section) => (
      <section class="wrap cv-section" aria-labelledby={slugify(section.title)}>
        <h2 id={slugify(section.title)} class="cv-section__title">
          {section.title}
        </h2>

        {section.kind === "dated" && section.lede && (
          <p class="cv-lede">{section.lede}</p>
        )}

        {section.kind === "grants" && (
          <>
            <p class="cv-lede">Total obtained as PI: <strong>{grantTotalPI}</strong></p>
            <ul class="cv-list" role="list">
              {grants.map((g) => (
                <li class="cv-entry">
                  <div class="cv-entry__body">
                    <p class="cv-entry__role">
                      {g.role} — {g.program}
                    </p>
                    <p class="cv-entry__note">{g.title}</p>
                  </div>
                  <span class="cv-entry__date">{g.date}</span>
                </li>
              ))}
            </ul>
          </>
        )}

        {section.kind === "advising" && (
          <>
            {(
              [
                ["Graduate students", graduateAdvisees],
                ["Undergraduate students", undergraduateAdvisees],
              ] as [string, Advisee[]][]
            ).map(([label, people]) => (
              <>
                <h3 class="cv-sub">{label}</h3>
                <ul class="cv-list" role="list">
                  {people.map((a) => (
                    <li class="cv-entry">
                      <div class="cv-entry__body">
                        <p class="cv-entry__role">
                          {a.name}
                          {a.refereed && <span class="cv-star" title="Led to a refereed publication">★</span>}
                        </p>
                        <p class="cv-entry__org">{a.affiliation}</p>
                        {a.project && <p class="cv-entry__note">{a.project}</p>}
                      </div>
                      <span class="cv-entry__date">{a.date}</span>
                    </li>
                  ))}
                </ul>
              </>
            ))}
            <p class="cv-note">
              <span class="cv-star">★</span> Denotes students whose project or
              contribution led to a refereed publication.
            </p>
          </>
        )}

        {section.kind === "dated" && (
          <ul class="cv-list" role="list">
            {section.entries.map((e) => (
              <li class="cv-entry">
                <div class="cv-entry__body">
                  <p class="cv-entry__role">
                    {e.roleHref ? (
                      <a href={e.roleHref} rel="noopener">
                        {e.role} ↗
                      </a>
                    ) : (
                      e.role
                    )}
                  </p>
                  {e.org && <p class="cv-entry__org">{e.org}</p>}
                  {e.note &&
                    (e.href ? (
                      <p class="cv-entry__note">
                        <a href={e.href} rel="noopener">{e.note}</a>
                      </p>
                    ) : (
                      <p class="cv-entry__note">{e.note}</p>
                    ))}
                </div>
                <span class="cv-entry__date">{e.date}</span>
              </li>
            ))}
          </ul>
        )}

        {section.kind === "pubs" && (
          <>
            <ol class="cv-pubs" role="list">
              {selectedPublications.map((p) => (
                <li class="cv-pub">
                  <p class="cv-pub__title">{p.title}</p>
                  <p class="cv-pub__authors">
                    {authorParts(p.authors).map((part) =>
                      part.bold ? <strong>{part.text}</strong> : part.text,
                    )}
                  </p>
                  <p class="cv-pub__meta">
                    <span class="cv-pub__venue">
                      {p.year} · {p.venue}
                    </span>
                    {p.status === "submitted" && (
                      <span class="cv-pub__badge">submitted</span>
                    )}
                    {p.ads && (
                      <a class="cv-pub__ads" href={p.ads} rel="noopener">
                        NASA ADS ↗
                      </a>
                    )}
                  </p>
                </li>
              ))}
            </ol>
            <p class="cv-note">
              Selected first-author work — see plain-language summaries on the{" "}
              <a href="/publications">publications page</a>, or the full record
              of {publicationCount} on{" "}
              <a href={cvProfile.orcid} rel="me noopener">ORCID</a>.
            </p>
          </>
        )}
      </section>
    ))
  }
</BaseLayout>

<style>
  .cv-top {
    padding-block-end: var(--space-xl);
  }
  .cv-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: var(--space-m);
  }
  .cv-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-m);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
  }
  .cv-stat__value {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 700;
    color: var(--spec-teal-bright);
    line-height: 1;
  }
  .cv-stat__label {
    font-size: var(--step--1);
    color: var(--ink-dim);
  }

  .cv-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    margin-block-start: var(--space-l);
  }
  .cv-btn {
    display: inline-block;
    padding: var(--space-2xs) var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .cv-btn:hover {
    border-color: var(--spec-teal-bright);
    color: var(--spec-teal-bright);
  }

  .cv-section {
    padding-block: var(--space-l);
  }
  .cv-section__title {
    font-size: var(--step-2);
    padding-block-end: var(--space-2xs);
    margin-block-end: var(--space-m);
    border-block-end: 1px solid var(--border);
    /* Jumping to /cv#software must not park the heading behind the site
       header + the sticky section nav. --header-h is published by SectionNav. */
    scroll-margin-block-start: calc(
      var(--header-h, 3.25rem) + var(--secnav-h, 3.5rem) + var(--space-m)
    );
  }

  .cv-list {
    display: grid;
    gap: var(--space-m);
  }
  .cv-entry {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-m);
    justify-content: space-between;
    align-items: baseline;
  }
  .cv-entry__role {
    font-weight: 600;
    color: var(--ink);
  }
  .cv-entry__org {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .cv-entry__note {
    color: var(--ink-dim);
    font-size: var(--step--1);
    font-style: italic;
    margin-block-start: var(--space-3xs);
  }
  .cv-entry__date {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-dim);
    white-space: nowrap;
  }

  .cv-pubs {
    display: grid;
    gap: var(--space-l);
    counter-reset: pub;
  }
  .cv-pub__title {
    font-weight: 600;
    color: var(--ink);
    margin-block-end: var(--space-3xs);
  }
  .cv-pub__authors {
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .cv-pub__authors strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }
  .cv-pub__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    margin-block-start: var(--space-3xs);
    font-size: var(--step--1);
    color: var(--ink-dim);
  }
  .cv-pub__badge {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
  }
  .cv-pub__ads {
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .cv-lede {
    max-inline-size: var(--width-prose);
    margin-block-end: var(--space-m);
    color: var(--ink-soft);
  }
  .cv-sub {
    font-size: var(--step-0);
    color: var(--spec-teal-bright);
    margin-block: var(--space-m) var(--space-2xs);
  }
  .cv-star {
    margin-inline-start: var(--space-3xs);
    color: var(--spec-teal-bright);
  }
  .cv-note {
    margin-block-start: var(--space-l);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }

  /*
   * Print: a CV gets printed. Because every section is one continuous
   * document (no tabs, no hidden panels), Cmd-P already yields the whole
   * record — this just makes it legible on paper and stops sections from
   * splitting across a page break mid-entry.
   */
  @media print {
    .cv-stats,
    .cv-actions {
      display: none;
    }
    .cv-section {
      padding-block: var(--space-s);
      break-inside: avoid;
    }
    .cv-entry,
    .cv-pub {
      break-inside: avoid;
    }
  }
</style>
