---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Figure from "../components/Figure.astro";
import { researchQuestions } from "../data/research";

const pad = (n: number) => String(n).padStart(2, "0");
---

<BaseLayout
  title="Research — Anna Rosen, Ph.D."
  description="A computational astrophysics program on massive-star formation, stellar feedback, star clusters, the initial mass function, and differentiable inference."
  path="/research"
  ogImage="research.png"
>
  <PageHeader
    eyebrow="Research"
    title="What do star clusters remember, forget, and reveal?"
    lede="Every question below is a facet of that one. I organize the work around questions, not topics — each spanning simulations, observations, and the software built to connect them."
  />

  <ol class="rq" role="list">
    {
      researchQuestions.map((q, i) => (
        <li class="rq__item">
          <span class="rq__index" aria-hidden="true">{pad(i + 1)}</span>
          <div class="rq__body">
            <h2 class="rq__question">{q.question}</h2>
            <p class="rq__summary prose">{q.summary}</p>
            <ul class="rq__threads" role="list">
              {q.threads.map((t) => (
                <li class="rq__thread">{t}</li>
              ))}
            </ul>
            {q.related && (
              <p class="rq__related">
                {q.related.map((r) => (
                  <a href={r.href}>{r.label} →</a>
                ))}
              </p>
            )}
            {q.figure && (
              <div class="rq__figure">
<Figure id={q.figure.id} caption="short" contain={q.figure.contain} />
              </div>
            )}
          </div>
        </li>
      ))
    }
  </ol>
</BaseLayout>

<style>
  .rq {
    inline-size: min(100% - var(--gutter) * 2, var(--width-content));
    margin-inline: auto;
    display: grid;
    gap: var(--space-2xl);
    padding-block: var(--space-l) var(--space-3xl);
  }

  .rq__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-m) var(--space-l);
    align-items: start;
    padding-block-start: var(--space-l);
    border-block-start: 1px solid var(--border);
  }

  .rq__index {
    font-family: var(--font-mono);
    font-size: var(--step-3);
    font-weight: 600;
    color: color-mix(in srgb, var(--spec-teal) 55%, transparent);
    line-height: 1;
  }

  .rq__question {
    font-size: var(--step-3);
    max-inline-size: 22ch;
    margin-block-end: var(--space-s);
    color: var(--ink);
  }
  .rq__summary {
    color: var(--ink-soft);
    font-size: var(--step-1);
  }

  .rq__threads {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs) var(--space-s);
    margin-block-start: var(--space-m);
  }
  .rq__thread {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-dim);
    padding: 2px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  .rq__related {
    margin-block-start: var(--space-m);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .rq__figure {
    margin-block-start: var(--space-l);
  }

  /* ── Narrow: index sits above the question ─────────────────────── */
  @media (max-width: 40rem) {
    .rq__item {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .rq__index {
      font-size: var(--step-2);
    }
  }
</style>
