---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { siteConfig, activeLinks } from "../lib/site";

const links = activeLinks();
---

<BaseLayout
  title="About — Anna Rosen, Ph.D."
  description="I am a computational astrophysicist and Assistant Professor of Astronomy at San Diego State University, studying massive stars, star clusters, feedback, and differentiable inference."
  path="/about"
>
  <PageHeader eyebrow="About" title="Anna Rosen" />

  <section class="about wrap">
    <figure class="about__photo">
      <img
        src="/images/photos/anna-discover-the-cosmos.webp"
        alt="Anna Rosen beside a shop window display headed “Discover the Cosmos”, adjusting a telescope on a tripod in front of a backdrop of the Sun and a spiral galaxy."
        width="620"
        height="790"
        loading="lazy"
        decoding="async"
      />
    </figure>

    <div class="about__body prose">
      <p>
        I am a computational astrophysicist and Assistant Professor of Astronomy
        at San Diego State University. I study how stars — especially massive
        stars and the clusters they are born in — form, reshape their
        surroundings through feedback, and imprint themselves on the stellar
        populations we observe. Increasingly, my group builds the differentiable
        scientific software needed to connect those models to real survey data,
        and to ask what that data can genuinely tell us.
      </p>
      <p>
        My early work used radiation-magnetohydrodynamic simulations to show how
        massive stars keep accreting against their own radiation, winds, and
        outflows, and how feedback from young clusters carves bubbles and stirs
        turbulence in the interstellar medium. That work now drives a broader
        program: the <strong>Jaxstro</strong> ecosystem — a JAX-native,
        differentiable pipeline from a cluster's birth to its survey observables,
        built to make astrophysical inference rigorous and its limits honest.
      </p>
      <p>
        My own path ran through community college: I transferred from Los
        Angeles Pierce College to UC Berkeley, earned my Ph.D. at UC Santa Cruz,
        and held NASA Einstein and ITC fellowships at Harvard and NSF and UC
        Chancellor's fellowships at UC San Diego before joining SDSU in 2023. At
        a Hispanic-Serving Institution, I mentor students — including
        community-college transfer students — and build glass-box,
        well-documented software so that doing real computational science is
        open to newcomers, not gated behind undocumented research code.
      </p>
    </div>

    <p class="about__links">
      <a href="/cv">Curriculum vitae →</a>
      <a href="/research">Research →</a>
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      {
        links.map((l) => (
          <a href={l.href} rel="me noopener">
            {l.label} ↗
          </a>
        ))
      }
    </p>
  </section>
</BaseLayout>

<style>
  /* Photo beside the prose on wide screens, above it on narrow. The measure
     stays the constraint on the text; the photo takes the leftover column. */
  .about {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: var(--space-xl);
    align-items: start;
    padding-block-end: var(--space-2xl);
  }
  .about__photo {
    order: 2;
    margin: 0;
  }
  .about__photo img {
    inline-size: 100%;
    block-size: auto;
    border-radius: var(--radius-m);
    box-shadow: 0 0 0 1px var(--border-strong);
  }
  .about__body {
    order: 1;
  }
  /* Explicit order: flex/grid ordering defaults to 0, so without this the
     links row sorted AHEAD of the prose, which has order: 1. */
  .about__links {
    order: 3;
    grid-column: 1 / -1;
  }
  @media (max-width: 54rem) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__photo {
      order: 1;
      max-inline-size: 20rem;
    }
    .about__body {
      order: 2;
    }
  }
  .about__body {
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .about__body p + p {
    margin-block-start: var(--space-m);
  }
  .about__body strong {
    color: var(--spec-teal-bright);
    font-weight: 600;
  }
  .about__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-m);
    border-block-start: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
</style>
