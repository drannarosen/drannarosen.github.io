---
/*
 * Per-package page: what it does, what is proven, what is coming.
 *
 * Designed to look deliberate with an EMPTY MDX body, because most bodies are
 * empty today and will fill in as each methods paper lands. The figure gallery
 * and the status block carry the page on their own.
 */
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { READINESS_LABEL, READINESS_STEPS, READINESS_TOTAL } from "../../data/jaxstro";
import { getPackages, type PackageEntry } from "../../lib/packages";

export async function getStaticPaths() {
  const packages = await getPackages();
  return packages.map((pkg, i) => ({
    params: { package: pkg.id },
    props: {
      pkg,
      prev: packages[i - 1] ?? null,
      next: packages[i + 1] ?? null,
    },
  }));
}

interface Props {
  pkg: PackageEntry;
  prev: PackageEntry | null;
  next: PackageEntry | null;
}

const { pkg, prev, next } = Astro.props;
const d = pkg.data;
const { Content } = await render(pkg);

// An empty MDX body still renders a component, so ask the raw source instead.
const hasProse = pkg.body != null && pkg.body.replace(/\{\/\*[\s\S]*?\*\/\}/g, "").trim().length > 0;
---

<BaseLayout
  title={`${d.name} — Jaxstro — Anna Rosen, Ph.D.`}
  description={d.description}
  path={`/software/${pkg.id}`}
  ogImage={d.figures[0] ? `software-${pkg.id}.png` : "software.png"}
  ogImageAlt={d.figures[0]?.alt ?? d.description}
>
  <PageHeader eyebrow={`Jaxstro · ${d.stage}`} title={d.name} lede={d.tagline} />

  <section class="wrap pk-top">
    <p class="pk-desc prose">{d.description}</p>

    <div class="pk-status">
      <p class="pk-status__label">Readiness</p>
      <span
        class="meter"
        title={d.maturity}
        aria-label={`Readiness: ${READINESS_LABEL[d.readiness]}`}
      >
        {Array.from({ length: READINESS_TOTAL }, (_, k) => k + 1).map((n) => (
          <span class:list={["meter__step", n <= READINESS_STEPS[d.readiness] && "is-on"]} />
        ))}
        <span class="meter__label">{READINESS_LABEL[d.readiness]}</span>
      </span>
      {d.maturity && d.maturity !== READINESS_LABEL[d.readiness] && (
        <span class="pk-note">{d.maturity}</span>
      )}
      {(d.repo || d.docs) && (
        <p class="pk-status__links">
          {d.repo && <a class="pk-link" href={d.repo} rel="noopener">Repository ↗</a>}
          {d.docs && <a class="pk-link" href={d.docs} rel="noopener">Preview docs ↗</a>}
        </p>
      )}
    </div>
  </section>

  {
    hasProse && (
      <article class="wrap editorial pk-prose">
        <Content />
      </article>
    )
  }

  {
    d.figures.length > 0 && (
      <section class="wrap pk-gallery" aria-labelledby="pk-figs">
        <h2 id="pk-figs" class="pk-h2">What's working</h2>
        {d.figures.map((f) => (
          <figure class:list={["pk-fig", `pk-fig--${f.captionPlacement}`]}>
            <img
              src={f.src}
              alt={f.alt}
              width={f.width}
              height={f.height}
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              {f.preliminary && <span class="pk-prelim">Preliminary</span>}
              <strong class="pk-figtitle">{f.title}.</strong> {f.caption}
            </figcaption>
          </figure>
        ))}
      </section>
    )
  }

  {
    d.upcoming && (
      <section class="wrap pk-next" aria-labelledby="pk-next-h">
        <h2 id="pk-next-h" class="pk-h2">What's coming</h2>
        <p class="pk-upcoming prose">{d.upcoming}</p>
      </section>
    )
  }

  <nav class="wrap pk-nav" aria-label="Pipeline">
    {prev ? (
      <a class="pk-nav__link" href={`/software/${prev.id}`}>
        ← {String(prev.data.order).padStart(2, "0")} {prev.data.name}
      </a>
    ) : (
      <span />
    )}
    <a class="pk-nav__all" href="/software">All packages</a>
    {next ? (
      <a class="pk-nav__link pk-nav__link--next" href={`/software/${next.id}`}>
        {String(next.data.order).padStart(2, "0")} {next.data.name} →
      </a>
    ) : (
      <span />
    )}
  </nav>
</BaseLayout>

<style>
  .pk-top {
    padding-block-end: var(--space-l);
  }
  .pk-desc {
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  /* Readiness is the page's headline status, so it gets a card rather than a
     line of loose text under the description. */
  .pk-status {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs) var(--space-m);
    margin-block-start: var(--space-l);
    padding: var(--space-s) var(--space-m);
    max-inline-size: fit-content;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-inline-start: 2px solid var(--spec-teal-bright);
    border-radius: var(--radius-m);
  }
  .pk-status__label {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-faint);
  }
  .pk-status__links {
    display: flex;
    gap: var(--space-m);
  }
  .pk-note {
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .pk-link {
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .pk-prose {
    padding-block-end: var(--space-l);
  }

  .pk-h2 {
    font-size: var(--step-1);
    padding-block-end: var(--space-2xs);
    margin-block-end: var(--space-m);
    border-block-end: 1px solid var(--border);
  }

  .pk-gallery {
    padding-block: var(--space-l);
  }
  /*
   * Caption placement. "below" is the default; "side" exists for tall figures,
   * where putting the caption alongside cuts the image's rendered height
   * roughly in half instead of letting a portrait dominate the page. That is a
   * layout fix, not a styling preference — a 1466x1639 figure at full column
   * width is 928px tall and swamps everything around it.
   */
  .pk-fig {
    margin-block-end: var(--space-xl);
    /* Evidence supports the argument; it does not outweigh it. */
    max-inline-size: min(100%, 52rem);
  }
  .pk-fig--side {
    display: grid;
    /* The IMAGE is capped and the caption takes the remainder — the reverse
       (image 1fr) let a portrait stay tall and squeezed the caption into a
       column too narrow to set at body size. */
    grid-template-columns: minmax(0, 30rem) minmax(0, 1fr);
    gap: var(--space-l);
    align-items: start;
    max-inline-size: min(100%, 62rem);
  }
  .pk-fig--above {
    display: flex;
    flex-direction: column-reverse;
  }
  .pk-fig--above figcaption {
    margin-block: 0 var(--space-s);
  }
  .pk-fig img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    background: #fff;
    padding: var(--space-2xs);
    border-radius: var(--radius-m);
    box-shadow:
      0 0 0 1px var(--border-strong),
      0 18px 40px -24px rgb(0 0 0 / 0.9);
  }
  .pk-fig figcaption {
    margin-block-start: var(--space-s);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .pk-fig--side figcaption {
    margin-block-start: 0;
    font-size: var(--step-0);
    /* Sticks alongside a tall figure instead of stranding the text at the top. */
    position: sticky;
    inset-block-start: calc(var(--header-h, 3.7rem) + var(--space-m));
  }
  .pk-figtitle {
    color: var(--ink);
    font-weight: 600;
  }
  /* Mirrors production_validated=false in the run's own provenance record. */
  .pk-prelim {
    display: inline-block;
    margin-inline-end: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
    vertical-align: 1px;
  }

  .pk-next {
    padding-block-end: var(--space-l);
  }
  .pk-upcoming {
    color: var(--ink-soft);
  }

  .pk-nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-m);
    padding-block: var(--space-l) var(--space-3xl);
    margin-block-start: var(--space-l);
    border-block-start: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .pk-nav__all {
    color: var(--ink-dim);
  }
  /* Two columns need real width; below that the caption returns beneath. */
  @media (max-width: 60rem) {
    .pk-fig--side {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .pk-fig--side figcaption {
      position: static;
      font-size: var(--step-0);
    }
  }

  @media (max-width: 34rem) {
    .pk-nav {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2xs);
    }
  }
</style>
