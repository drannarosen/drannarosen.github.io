---
import BaseLayout from "../layouts/BaseLayout.astro";
import ClusterHero from "../components/ClusterHero.astro";

const title = "Anna Rosen — Computational Astrophysicist";
const description =
  "Anna Rosen builds physics-grounded models of stars and stellar systems, and the differentiable scientific software needed to understand them.";

// Provisional content — replace with real records as the content system grows.
const nowBuilding = [
  {
    label: "Differentiable stellar evolution",
    note: "Stellar tracks you can take gradients through.",
  },
  {
    label: "Grounded stellar-system dynamics",
    note: "JAX N-body for clusters and their feedback.",
  },
  {
    label: "Stellar-population inference",
    note: "What observations can genuinely constrain.",
  },
  {
    label: "Scientific learning environments",
    note: "Software that changes what students can see.",
  },
];
---

<BaseLayout title={title} description={description} path="/">
  <ClusterHero
    eyebrow="Computational Astrophysics · SDSU"
    heading="I build models of stars and stellar systems — and the software to understand them."
    lede="Anna Rosen is a computational astrophysicist and Assistant Professor of Astronomy at San Diego State University, connecting stellar evolution, cluster dynamics, feedback, synthetic observations, and inference through differentiable scientific software."
  >
    <nav class="hero-links" aria-label="Primary">
      <a href="/research">Research</a>
      <a href="/software">Software</a>
      <a href="/group">Group</a>
      <a href="/cv">CV</a>
      <a href="/contact">Contact</a>
    </nav>
  </ClusterHero>

  <section class="now wrap" aria-labelledby="now-heading">
    <p class="now__kicker">What I'm building now</p>
    <h2 id="now-heading">A single connected program</h2>
    <p class="now__lede prose">
      Research questions, scientific software, and teaching are not separate
      boxes — they are one effort to understand how stars shape the universe.
    </p>
    <ul class="now__grid" role="list">
      {
        nowBuilding.map((item) => (
          <li class="now__card">
            <h3 class="now__card-title">{item.label}</h3>
            <p class="now__card-note">{item.note}</p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
  }
  .hero-links a {
    color: var(--ink-soft);
    text-decoration: none;
    padding-block-end: 2px;
    border-block-end: 1px solid transparent;
  }
  .hero-links a:hover {
    color: var(--ink);
    border-block-end-color: var(--spec-cyan);
  }

  .now {
    padding-block: var(--space-3xl);
  }
  .now__kicker {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--spec-amber);
    margin-block-end: var(--space-2xs);
  }
  .now__lede {
    color: var(--ink-soft);
    margin-block: var(--space-s) var(--space-xl);
  }
  .now__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--space-m);
  }
  .now__card {
    padding: var(--space-m);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .now__card:hover {
    border-color: var(--border-strong);
  }
  .now__card-title {
    font-size: var(--step-1);
    margin-block-end: var(--space-2xs);
  }
  .now__card-note {
    font-size: var(--step-0);
    color: var(--ink-dim);
  }
</style>
