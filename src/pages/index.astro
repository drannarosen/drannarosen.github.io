---
import BaseLayout from "../layouts/BaseLayout.astro";
import ClusterHero from "../components/ClusterHero.astro";

const title = "Anna Rosen — Computational Astrophysicist";
const description =
  "Anna Rosen builds physics-grounded models of stars and stellar systems, and the differentiable scientific software needed to understand them.";

const nowBuilding = [
  {
    label: "Differentiable cluster inference",
    note: "The JAXSTRO pipeline — asking what survey data can truly recover about star clusters.",
    href: "/software",
  },
  {
    label: "The IMF, done honestly",
    note: "When ignoring unresolved binaries makes population inference confidently wrong.",
    href: "/research",
  },
  {
    label: "Collisional dynamics in JAX",
    note: "gravax: resolving close stellar encounters exactly, at cluster scale.",
    href: "/software",
  },
  {
    label: "Glass-box teaching tools",
    note: "Cosmic Playground and learner-centered documentation for real computational science.",
    href: "/teaching",
  },
];
---

<BaseLayout title={title} description={description} path="/">
  <ClusterHero
    eyebrow="Computational Astrophysics · SDSU"
    heading="Stars shape the universe. I build the models — and the software — to understand how."
    lede="I'm a computational astrophysicist at San Diego State University. I build differentiable models of stars and star clusters — and the JAXSTRO software that connects them to observations and inference."
  >
    <div class="hero-cta">
      <a class="btn btn--primary" href="/research">Explore the research</a>
      <a class="btn" href="/software">See the software</a>
    </div>
  </ClusterHero>

  <section class="now wrap" aria-labelledby="now-heading">
    <p class="now__kicker">What I'm building now</p>
    <h2 id="now-heading">A single connected program</h2>
    <p class="now__lede prose">
      Research questions, scientific software, and teaching are not separate
      boxes — they are one effort to understand how stars shape the universe.
    </p>
    <ul class="now__grid" role="list">
      {
        nowBuilding.map((item) => (
          <li>
            <a class="now__card" href={item.href}>
              <h3 class="now__card-title">{item.label}</h3>
              <p class="now__card-note">{item.note}</p>
              <span class="now__card-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }
  .btn {
    display: inline-block;
    padding: var(--space-2xs) var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }
  .btn:hover {
    border-color: var(--spec-cyan);
    background: color-mix(in oklch, var(--spec-cyan) 12%, transparent);
  }
  .btn--primary {
    background: color-mix(in oklch, var(--spec-blue) 22%, transparent);
    border-color: color-mix(in oklch, var(--spec-blue) 55%, transparent);
  }
  .btn--primary:hover {
    background: color-mix(in oklch, var(--spec-blue) 32%, transparent);
    border-color: var(--spec-blue);
  }

  .now {
    padding-block: var(--space-3xl);
  }
  .now__kicker {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--spec-rose);
    margin-block-end: var(--space-2xs);
  }
  .now__lede {
    color: var(--ink-soft);
    margin-block: var(--space-s) var(--space-xl);
  }
  .now__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--space-m);
  }
  .now__card {
    display: block;
    position: relative;
    block-size: 100%;
    padding: var(--space-m);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--dur-base) var(--ease-out),
      background-color var(--dur-base) var(--ease-out);
  }
  .now__card:hover {
    border-color: color-mix(in srgb, var(--spec-teal) 45%, var(--border));
    background: color-mix(in srgb, var(--spec-teal) 7%, var(--bg-deep));
  }
  .now__card-title {
    font-size: var(--step-1);
    color: var(--ink);
    margin-block-end: var(--space-2xs);
  }
  .now__card-note {
    font-size: var(--step-0);
    color: var(--ink-dim);
  }
  .now__card-arrow {
    display: inline-block;
    margin-block-start: var(--space-s);
    color: var(--spec-teal-bright);
    transition: transform var(--dur-base) var(--ease-out);
  }
  .now__card:hover .now__card-arrow {
    transform: translateX(4px);
  }
</style>
