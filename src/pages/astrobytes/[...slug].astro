---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

export async function getStaticPaths() {
  const posts = await getCollection("astrobytes", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<"astrobytes">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, dek, date, paper, level } = post.data;

// Format in UTC: frontmatter dates are bare (2026-07-19) and parse to UTC
// midnight, so formatting in a west-of-UTC local zone would render a day early.
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout
  title={`${title} — Astrobytes — Anna Rosen, Ph.D.`}
  description={dek}
  path={`/astrobytes/${post.id}`}
>
  <PageHeader eyebrow="Astrobytes" title={title} lede={dek} />

  <div class="wrap post-meta">
    <p class="post-meta__line">
      <time datetime={date.toISOString()}>{fmt(date)}</time>
      <span class="post-meta__level">{level}</span>
    </p>
    <div class="post-paper">
      <p class="post-paper__label">The paper</p>
      <p class="post-paper__title">{paper.title}</p>
      <p class="post-paper__cite">
        {paper.authors} · {paper.venue} ({paper.year}){
          paper.status && paper.status !== "published" && (
            <span class="post-paper__status">{paper.status}</span>
          )
        }
      </p>
      <p class="post-paper__links">
        {paper.arxiv && <a href={paper.arxiv} rel="noopener">arXiv ↗</a>}
        {paper.ads && <a href={paper.ads} rel="noopener">NASA ADS ↗</a>}
      </p>
    </div>
  </div>

  <article class="wrap editorial post">
    <Content />
  </article>

  <div class="wrap post-foot">
    <a href="/astrobytes">← All astrobytes</a>
  </div>
</BaseLayout>

<style>
  .post-meta {
    padding-block-end: var(--space-l);
  }
  .post-meta__line {
    display: flex;
    gap: var(--space-s);
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .post-meta__level {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.66rem;
    color: var(--ink-faint);
  }
  .post-paper {
    margin-block-start: var(--space-m);
    padding: var(--space-m);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    max-inline-size: 66ch;
  }
  .post-paper__label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .post-paper__title {
    margin-block-start: var(--space-3xs);
    font-weight: 600;
    color: var(--ink);
  }
  .post-paper__cite {
    margin-block-start: var(--space-3xs);
    font-size: var(--step--1);
    color: var(--ink-soft);
  }
  .post-paper__status {
    margin-inline-start: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
  }
  .post-paper__links {
    display: flex;
    gap: var(--space-m);
    margin-block-start: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  /* Layout, figures, tables and editorial elements come from
     src/styles/editorial.css via the `editorial` class, so any future
     long-form collection gets the same treatment for free. */
  .post {
    padding-block-end: var(--space-2xl);
  }

  .post-foot {
    padding-block-end: var(--space-3xl);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
</style>
