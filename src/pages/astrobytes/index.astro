---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ProvenanceBadge from "../../components/post/ProvenanceBadge.astro";

const posts = (await getCollection("astrobytes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Format in UTC: frontmatter dates are bare (2026-07-19) and parse to UTC
// midnight, so formatting in a west-of-UTC local zone would render a day early.
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout
  title="Astrobytes — Anna Rosen, Ph.D."
  description="Plain-language write-ups of astronomy papers for students and the curious: what was measured, how, and what it does and does not show. No jargon assumed."
  path="/astrobytes"
>
  <PageHeader
    eyebrow="Astrobytes"
    title="Papers, in plain language"
    lede="Astronomy papers, explained. What was measured, the mechanism behind the result, and — the part papers usually bury — what it does not show. Written for students and curious readers, not for specialists."
  />

  <div class="wrap ab-note">
    <div class="prose flow">
    <p>
      If you have ever opened an astronomy paper and bounced off the first
      paragraph, these are for you. No prior coursework assumed — I define the
      jargon where it comes up, and I try to be clear about what a result
      actually establishes as opposed to what it hints at.
    </p>
    <p>
      Looking for my formal publication record instead? It lives on{" "}
      <a href="/publications">Publications</a>.
    </p>
    <p>
      Named in the spirit of <a href="https://astrobites.org" rel="noopener">Astrobites</a>,
      the graduate-student-run paper digest, where I was an early author. These
      posts are my own and are not affiliated with Astrobites.
    </p>
    <p>
      <a href="/astrobytes/rss.xml">Subscribe by RSS</a> — no account, no
      algorithm, nothing tracking you.
    </p>
  </div>
  </div>

  <ul class="wrap ab-list" role="list">
    {
      posts.map((p) => (
        <li class="ab-card">
          <p class="ab-card__meta">
            <time datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
            <span class="ab-card__level">{p.data.level}</span>
            <ProvenanceBadge provenance={p.data.provenance} compact />
          </p>
          <h2 class="ab-card__title">
            <a href={`/astrobytes/${p.id}`}>{p.data.title}</a>
          </h2>
          <p class="ab-card__dek prose">{p.data.dek}</p>
          {p.data.paper && (
            <p class="ab-card__paper">
              on{" "}
              <cite>
                <a href={p.data.paper.ads} rel="noopener">{p.data.paper.title}</a>
              </cite>{" "}
              — {p.data.paper.authors} ({p.data.paper.year})
            </p>
          )}
        </li>
      ))
    }
    {posts.length === 0 && <li class="ab-empty">No posts yet.</li>}
  </ul>
</BaseLayout>

<style>
  .ab-note {
    padding-block-end: var(--space-l);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }
  .ab-list {
    display: grid;
    gap: var(--space-l);
    padding-block-end: var(--space-3xl);
  }
  .ab-card {
    padding-block-start: var(--space-m);
    border-block-start: 1px solid var(--border);
  }
  .ab-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-dim);
  }
  .ab-card__level {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--step--2);
    color: var(--ink-faint);
  }
  .ab-card__title {
    font-size: var(--step-2);
    max-inline-size: 34ch;
    margin-block: var(--space-3xs) var(--space-2xs);
  }
  .ab-card__title a {
    color: var(--ink);
    text-decoration-color: var(--border);
  }
  .ab-card__title a:hover {
    text-decoration-color: var(--spec-teal-bright);
  }
  .ab-card__dek {
    color: var(--ink-soft);
    max-inline-size: 62ch;
  }
  .ab-card__paper {
    margin-block-start: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--ink-dim);
  }
  .ab-empty {
    color: var(--ink-dim);
  }
</style>
