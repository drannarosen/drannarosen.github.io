---
/*
 * CensusEngine.astro — the first novascope engine (Layer 3). Four panels in two
 * rows: top, the cluster (2-D or orbitable 3-D) and its H–R diagram; bottom, the
 * controls and the live IMF histogram — the distribution you're dragging, right
 * next to the slider that shapes it. All physics comes from star() via the
 * selectors; this file is glue + chrome. Styled with --xpl-* tokens (site
 * fallbacks); the style block is global because the readout card is injected
 * client-side and would miss Astro-scoped selectors.
 *
 * Math is real KaTeX, rendered at BUILD time here (no Unicode "M☉"/"T_eff"): the
 * component imports katex directly (self-contained for extraction, not the site's
 * Math.astro), and JS fills only plain-number values into the typeset skeletons.
 * Canvas tick labels are plain ASCII; axis titles live in HTML KaTeX captions.
 */
import katex from "katex";
const m = (tex: string, display = false) =>
  katex.renderToString(tex, { throwOnError: false, displayMode: display, output: "htmlAndMathml" });
---

<div class="xpl-census" data-census>
  <div class="xpl-census__grid">
    <figure class="xpl-census__panel" data-lit="structure">
      <figcaption>
        The cluster
        <span class="xpl-census__modes" role="group" aria-label="Cluster view">
          <button type="button" data-mode="2D" class="is-active">2D</button>
          <button type="button" data-mode="3D">3D</button>
        </span>
      </figcaption>
      <canvas data-field aria-label="Star cluster; hover a star to inspect it, drag to orbit in 3D"></canvas>
      <small class="xpl-census__hint" data-hint></small>
      <div class="xpl-census__presets" role="group" aria-label="Quick-start presets">
        <button type="button" data-preset-btn="default">typical</button>
        <button type="button" data-preset-btn="lowMass">low-mass</button>
        <button type="button" data-preset-btn="starburst">starburst</button>
        <button type="button" data-preset-btn="diffuse">diffuse</button>
        <button type="button" data-preset-btn="segregated">segregated</button>
      </div>
    </figure>

    <figure class="xpl-census__panel xpl-census__panel--hr" data-lit="census">
      <figcaption>H–R diagram <span>log–log; hotter left</span></figcaption>
      <div class="xpl-census__plot">
        <span class="xpl-census__ytitle" set:html={m("L/L_\\odot")} />
        <canvas data-hr aria-label="Hertzsprung-Russell diagram of the cluster; hover to preview, click to pin"></canvas>
        <span class="xpl-census__xtitle" set:html={m("T_\\mathrm{eff}\\;(\\mathrm{K})")} />
      </div>
      <aside class="xpl-census__card" data-card hidden>
        <span class="xpl-census__swatch" data-swatch></span>
        <dl>
          <div><dt>mass</dt><dd><span data-v="mass">—</span> <span set:html={m("M_\\odot")} /></dd></div>
          <div><dt>type</dt><dd data-v="type">—</dd></div>
          <div><dt><span set:html={m("T_\\mathrm{eff}")} /></dt><dd><span data-v="teff">—</span> K</dd></div>
          <div><dt><span set:html={m("\\log_{10} L/L_\\odot")} /></dt><dd data-v="logl">—</dd></div>
          <div><dt>radius</dt><dd><span data-v="radius">—</span> <span set:html={m("R_\\odot")} /></dd></div>
          <div><dt>phase</dt><dd data-v="phase">—</dd></div>
        </dl>
      </aside>
    </figure>

    <div class="xpl-census__panel xpl-census__panel--pad">
      <div class="xpl-census__toolbar">
        <div class="xpl-census__lenses" role="group" aria-label="Lenses — turn on more than one to experiment across groups on the same cluster">
          <button type="button" data-lens-chip="census" class="is-active" aria-pressed="true">Census</button>
          <button type="button" data-lens-chip="environment" aria-pressed="false">Environment</button>
          <button type="button" data-lens-chip="structure" aria-pressed="false">Structure</button>
        </div>
        <button type="button" class="xpl-census__reseed" data-reseed>↻ new draw</button>
      </div>

      <div class="xpl-census__controls">
        <section class="xpl-census__lens" data-lens="census" aria-label="Census controls">
          <p class="xpl-census__lenshd"><b>Census</b> — how many stars of each mass?</p>
          <div class="xpl-census__lensgrid">
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">high-mass slope</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("\\alpha")} /> = <output data-slope-val>2.3</output></span>
              <input type="range" data-slope min="1.5" max="3" step="0.1" value="2.3" />
              <small>top-heavy ← → bottom-heavy</small>
            </label>
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">stars</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("N")} /> = <output data-count-val>1200</output></span>
              <input type="range" data-count min="1.301" max="4.301" step="0.01" value="3.079" />
              <small>watch the rare massive tail flicker</small>
            </label>
          </div>
        </section>

        <section class="xpl-census__lens" data-lens="environment" aria-label="Environment controls" hidden>
          <p class="xpl-census__lenshd"><b>Environment</b> — what sets the slope?</p>
          <label class="xpl-census__check">
            <input type="checkbox" data-envmode />
            <span>environment-driven <span set:html={m("\\alpha")} /> (Marks/Jerabkova)</span>
          </label>
          <div class="xpl-census__envctrls" data-envctrls hidden>
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">metallicity</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("[\\mathrm{Fe}/\\mathrm{H}]")} /> = <output data-feh-val>0.0</output></span>
              <input type="range" data-feh min="-2" max="0.5" step="0.1" value="0" />
              <small>metal-poor → top-heavy</small>
            </label>
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">cluster mass</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("\\log_{10} M_\\mathrm{ecl}")} /> = <output data-mecl-val>4.0</output></span>
              <input type="range" data-mecl min="3" max="4.3" step="0.1" value="4" />
              <small>→ more stars, top-heavier</small>
            </label>
          </div>
        </section>

        <section class="xpl-census__lens" data-lens="structure" aria-label="Structure controls" hidden>
          <div class="xpl-census__lenshd xpl-census__lenshd--split">
            <span><b>Structure</b> — where do stars live?</span>
            <button type="button" class="xpl-census__info" data-info="profile" aria-expanded="false" aria-label="About the spatial profile">?</button>
            <div class="xpl-census__popover" data-popover="profile" role="tooltip" hidden>
              <b>Spatial profile</b> — an EFF (Elson+1987) sphere, <span set:html={m("\\rho \\propto (1 + r^2/a^2)^{-\\gamma/2}")} />. <span set:html={m("\\gamma = 5")} /> is the classic Plummer sphere; lower <span set:html={m("\\gamma")} /> spreads stars into an extended power-law halo.
            </div>
          </div>
          <div class="xpl-census__lensgrid">
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">concentration</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("\\gamma")} /> = <output data-gamma-val>5.0</output></span>
              <input type="range" data-gamma min="2.5" max="6" step="0.1" value="5" />
              <small>5 = Plummer; lower = extended</small>
            </label>
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">segregation</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("\\lambda")} /> = <output data-seg-val>0.0</output></span>
              <input type="range" data-seg min="0" max="1" step="0.05" value="0" />
              <small>massive stars sink to the core</small>
            </label>
            <label class="xpl-census__ctrl">
              <span class="xpl-census__ctrl-name">half-mass radius</span>
              <span class="xpl-census__ctrl-val"><span set:html={m("r_h")} /> = <output data-rh-val>1.3</output> pc</span>
              <input type="range" data-rh min="0.3" max="5" step="0.1" value="1.3" />
              <small>compact ← → diffuse</small>
            </label>
          </div>
        </section>
      </div>
    </div>

    <figure class="xpl-census__panel" data-lit="census environment">
      <figcaption>
        The IMF
        <span class="xpl-census__modes" role="group" aria-label="IMF form">
          <button type="button" data-imfform="dNdM" class="is-active">dN/dM</button>
          <button type="button" data-imfform="perDex">dN/dlog m</button>
        </span>
      </figcaption>
      <div class="xpl-census__plot">
        <span class="xpl-census__ytitle" data-imfy="dNdM" set:html={m("\\xi(m)=\\mathrm{d}N/\\mathrm{d}M")} />
        <span class="xpl-census__ytitle" data-imfy="perDex" hidden set:html={m("\\mathrm{d}N/\\mathrm{d}\\log m")} />
        <canvas data-imf aria-label="Initial mass function: sampled bars against the analytic Maschberger law"></canvas>
        <span class="xpl-census__xtitle" set:html={m("\\mathrm{mass}\\;(M_\\odot)")} />
      </div>
      <dl class="xpl-census__stats" data-summary aria-live="polite">
        <div><dt>stars</dt><dd data-v="n">—</dd></div>
        <div><dt>O-type (≥16 <span set:html={m("M_\\odot")} />)</dt><dd data-v="o">—</dd></div>
        <div><dt>heaviest</dt><dd><span data-v="heaviest">—</span> <span set:html={m("M_\\odot")} /></dd></div>
        <div><dt>median mass</dt><dd><span data-v="median">—</span> <span set:html={m("M_\\odot")} /></dd></div>
        <div><dt>total mass</dt><dd><span data-v="total">—</span> <span set:html={m("M_\\odot")} /></dd></div>
      </dl>
    </figure>
  </div>

  <noscript>
    <p class="xpl-census__noscript">
      This interactive samples and renders a star cluster in your browser — enable
      JavaScript to explore it. The surrounding text explains what it shows.
    </p>
  </noscript>
</div>

<script>
  import { createClusterStore, toRenderModel, toHRModel, toIMFHistogram, localStorageAdapter } from "../state/index.ts";
  import { defaultIdentity, sampleCluster, presets, effRhOverA, type ClusterIdentity } from "../core/cluster/index.ts";
  import { star } from "../core/stellar/index.ts";
  import { alpha3FromEnvironment } from "../core/imf/index.ts";
  import { mountCanvas, makeCamera, attachOrbit, renderClusterField, pickStar, renderHR, pickHRPoint, renderHistogram } from "../viz/index.ts";

  const root = document.querySelector<HTMLElement>("[data-census]");
  if (root) {
    const $ = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const fieldCanvas = $<HTMLCanvasElement>("[data-field]");
    const hrCanvas = $<HTMLCanvasElement>("[data-hr]");
    const imfCanvas = $<HTMLCanvasElement>("[data-imf]");
    const slope = $<HTMLInputElement>("[data-slope]");
    const slopeVal = $<HTMLOutputElement>("[data-slope-val]");
    const count = $<HTMLInputElement>("[data-count]");
    const countVal = $<HTMLOutputElement>("[data-count-val]");
    const seg = $<HTMLInputElement>("[data-seg]");
    const segVal = $<HTMLOutputElement>("[data-seg-val]");
    const rh = $<HTMLInputElement>("[data-rh]");
    const rhVal = $<HTMLOutputElement>("[data-rh-val]");
    const envmode = $<HTMLInputElement>("[data-envmode]");
    const envctrls = $<HTMLElement>("[data-envctrls]");
    const feh = $<HTMLInputElement>("[data-feh]");
    const fehVal = $<HTMLOutputElement>("[data-feh-val]");
    const mecl = $<HTMLInputElement>("[data-mecl]");
    const meclVal = $<HTMLOutputElement>("[data-mecl-val]");
    const presetBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-preset-btn]"));
    const setActivePreset = (key: string | null) =>
      presetBtns.forEach((b) => b.classList.toggle("is-active", b.dataset.presetBtn === key));
    const card = $<HTMLElement>("[data-card]");
    const summary = $<HTMLElement>("[data-summary]");
    const hint = $<HTMLElement>("[data-hint]");

    const store = createClusterStore({
      adapter: localStorageAdapter(),
      instance: "census",
      identity: defaultIdentity({ sampling: { mode: "count", target: 1200 }, imf: { mMin: 0.1, mMax: 100, alphaHigh: 2.3 } }),
    });

    const camera = makeCamera(store.getView().toggles.threeD ? "3D" : "2D");

    let latent = sampleCluster(store.getIdentity());
    let rm = toRenderModel(latent, store.getView());
    let hr = toHRModel(latent, store.getView());
    let imf = toIMFHistogram(latent, store.getIdentity());

    // Controls are synced to the (possibly restored/preset) identity by
    // syncControls(), defined + called once all refs exist, below.

    let hoverId: number | null = null; // transient preview; pinned lives in the store
    let imfForm: "dNdM" | "perDex" = "dNdM"; // IMF plot form (ξ line vs per-dex hump)

    const field = mountCanvas(fieldCanvas, (ctx, w, h) =>
      renderClusterField(ctx, rm, w, h, { camera, selectedId: store.getView().selectedId, hoverId }),
    );
    const hrView = mountCanvas(hrCanvas, (ctx, w, h) =>
      renderHR(ctx, hr, w, h, { selectedId: store.getView().selectedId, hoverId }),
    );
    const imfView = mountCanvas(imfCanvas, (ctx, w, h) => renderHistogram(ctx, imf, w, h, { form: imfForm }));

    attachOrbit(fieldCanvas, camera, () => field.redraw());

    function recompute() {
      rm = toRenderModel(latent, store.getView());
      hr = toHRModel(latent, store.getView());
      imf = toIMFHistogram(latent, store.getIdentity());
      field.redraw();
      hrView.redraw();
      imfView.redraw();
      updateSummary();
      updateCard(hoverId ?? store.getView().selectedId);
    }
    function patchIdentity(patch: Partial<ClusterIdentity>) {
      store.setIdentity({ ...store.getIdentity(), ...patch });
      latent = sampleCluster(store.getIdentity());
      setActivePreset(null); // a manual change → no preset highlighted
      recompute();
    }

    slope.addEventListener("input", () => {
      const a = Number(slope.value);
      slopeVal.value = a.toFixed(1);
      patchIdentity({ imf: { ...store.getIdentity().imf, alphaHigh: a } });
    });
    count.addEventListener("input", () => {
      const n = Math.round(10 ** Number(count.value));
      countVal.value = n.toLocaleString();
      patchIdentity({ sampling: { mode: "count", target: n } });
    });
    // Environment mode (Marks/Jerabkova): [Fe/H] + M_ecl set BOTH the IMF slope
    // α AND the cluster's total stellar mass — M_ecl *is* that mass, so we sample
    // mass-limited to it. Both α and N (star count) become derived; the slider
    // max is capped so the drawn population stays renderable (no OOM).
    const applyEnv = () => {
      const mEcl = 10 ** Number(mecl.value);
      const a = Math.min(2.8, Math.max(1.1, alpha3FromEnvironment(Number(feh.value), mEcl)));
      slope.value = a.toFixed(2);
      slopeVal.value = a.toFixed(2);
      patchIdentity({
        imf: { ...store.getIdentity().imf, alphaHigh: a },
        sampling: { mode: "mass", target: mEcl },
      });
      // N is now an outcome of (M_ecl, α), not an input — reflect the draw.
      countVal.value = latent.length.toLocaleString();
      count.value = String(Math.min(Number(count.max), Math.log10(Math.max(1, latent.length))));
    };
    envmode.addEventListener("change", () => {
      envctrls.hidden = !envmode.checked;
      slope.disabled = envmode.checked; // α is derived in env mode
      count.disabled = envmode.checked; // …and so is N (M_ecl sets the mass)
      if (envmode.checked) applyEnv();
      else patchIdentity({ sampling: { mode: "count", target: Math.round(10 ** Number(count.value)) } });
    });
    feh.addEventListener("input", () => {
      fehVal.value = Number(feh.value).toFixed(1);
      applyEnv();
    });
    mecl.addEventListener("input", () => {
      meclVal.value = Number(mecl.value).toFixed(1);
      applyEnv();
    });

    seg.addEventListener("input", () => {
      const v = Number(seg.value);
      segVal.value = v.toFixed(2);
      patchIdentity({ segregation: v });
    });
    // Structure geometry: one EFF profile. γ sets concentration (5 = Plummer),
    // r_h is the half-mass radius. They're orthogonal — scaleRadius is derived
    // from r_h through the ACTUAL EFF half-mass ratio for the current γ, so the
    // quoted r_h stays true at every γ, not only the Plummer case.
    const gamma = $<HTMLInputElement>("[data-gamma]");
    const gammaVal = $<HTMLOutputElement>("[data-gamma-val]");
    const setGeometry = (rhPc: number, g: number) =>
      patchIdentity({ profile: { kind: "eff", scaleRadius: rhPc / effRhOverA(g), gamma: g } });
    rh.addEventListener("input", () => {
      const v = Number(rh.value); // r_h in pc
      rhVal.value = v.toFixed(1);
      setGeometry(v, Number(gamma.value));
    });
    gamma.addEventListener("input", () => {
      const g = Number(gamma.value);
      gammaVal.value = g.toFixed(1);
      setGeometry(Number(rh.value), g); // hold r_h fixed as the shape changes
    });

    // "?" popover explaining the spatial profile (click to toggle, click-away closes).
    const infoBtn = root.querySelector<HTMLButtonElement>('[data-info="profile"]');
    const popover = root.querySelector<HTMLElement>('[data-popover="profile"]');
    if (infoBtn && popover) {
      const setOpen = (open: boolean) => {
        popover.hidden = !open;
        infoBtn.setAttribute("aria-expanded", String(open));
      };
      infoBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        setOpen(popover.hidden);
      });
      document.addEventListener("click", (e) => {
        if (!popover.hidden && e.target instanceof Node && !popover.contains(e.target)) setOpen(false);
      });
    }

    // Reflect the current identity onto every control (initial load + presets).
    function syncControls() {
      const id = store.getIdentity();
      slope.value = String(id.imf.alphaHigh);
      slopeVal.value = id.imf.alphaHigh.toFixed(2);
      slope.disabled = false;
      count.disabled = false;
      count.value = String(Math.log10(id.sampling.target));
      countVal.value = id.sampling.target.toLocaleString();
      seg.value = String(id.segregation);
      segVal.value = id.segregation.toFixed(2);
      const g = id.profile.gamma ?? 5; // 5 = Plummer sphere
      gamma.value = String(g);
      gammaVal.value = g.toFixed(1);
      const rhv = id.profile.scaleRadius * effRhOverA(g); // true half-mass radius at this γ
      rh.value = rhv.toFixed(1);
      rhVal.value = rhv.toFixed(1);
      envmode.checked = false;
      envctrls.hidden = true;
    }

    // "Strange universe" presets — a jump to a whole named identity, sat below
    // the cluster it reshapes. The highlight clears on any manual tweak (via
    // patchIdentity → setActivePreset(null)), the old dropdown's "— custom —".
    presetBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const p = presets[b.dataset.presetBtn!];
        if (!p) return;
        store.setIdentity(structuredClone(p));
        latent = sampleCluster(store.getIdentity());
        syncControls();
        recompute();
        setActivePreset(b.dataset.presetBtn!);
      }),
    );

    syncControls();
    $<HTMLButtonElement>("[data-reseed]").addEventListener("click", () => {
      patchIdentity({ seed: (store.getIdentity().seed * 1103515245 + 12345) >>> 0 });
    });

    // 2-D / 3-D toggle.
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const setMode = (mode: "2D" | "3D") => {
      camera.mode = mode;
      camera.yaw = mode === "3D" ? 0.5 : 0;
      camera.pitch = mode === "3D" ? 0.35 : 0;
      camera.zoom = 1;
      camera.panX = 0;
      camera.panY = 0;
      store.setView({ toggles: { ...store.getView().toggles, threeD: mode === "3D" } });
      modeBtns.forEach((b) => b.classList.toggle("is-active", b.dataset.mode === mode));
      hint.textContent = mode === "3D" ? "drag to orbit · scroll to zoom · shift-drag to pan" : "scroll to zoom · drag to pan";
      field.redraw();
    };
    modeBtns.forEach((b) => b.addEventListener("click", () => setMode(b.dataset.mode as "2D" | "3D")));
    setMode(camera.mode);

    // IMF form toggle (ξ = dN/dM line ↔ per-dex hump).
    const imfBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-imfform]"));
    const yTitles = Array.from(root.querySelectorAll<HTMLElement>("[data-imfy]"));
    imfBtns.forEach((b) =>
      b.addEventListener("click", () => {
        imfForm = b.dataset.imfform as "dNdM" | "perDex";
        imfBtns.forEach((x) => x.classList.toggle("is-active", x === b));
        yTitles.forEach((el) => (el.hidden = el.dataset.imfy !== imfForm));
        imfView.redraw();
      }),
    );

    // Lens tiers: multi-select chips over ONE cluster. One on = guided focus; two
    // on = compare knob-groups side by side on the SAME population (nothing is
    // re-drawn — a chip only toggles which knobs show). The panels a lens drives
    // get a subtle border while it is active. Local state, like the IMF-form
    // toggle — the cluster identity is untouched, so no persistence is needed.
    const lensChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lens-chip]"));
    const lensSections = Array.from(root.querySelectorAll<HTMLElement>("[data-lens]"));
    const litPanels = Array.from(root.querySelectorAll<HTMLElement>("[data-lit]"));
    const activeLenses = new Set<string>(["census"]);
    const applyLenses = () => {
      lensChips.forEach((c) => {
        const on = activeLenses.has(c.dataset.lensChip!);
        c.classList.toggle("is-active", on);
        c.setAttribute("aria-pressed", String(on));
      });
      lensSections.forEach((s) => (s.hidden = !activeLenses.has(s.dataset.lens!)));
      litPanels.forEach((p) =>
        p.classList.toggle("is-lit", (p.dataset.lit ?? "").split(" ").some((l) => activeLenses.has(l))),
      );
    };
    lensChips.forEach((c) =>
      c.addEventListener("click", () => {
        const key = c.dataset.lensChip!;
        if (activeLenses.has(key)) {
          if (activeLenses.size > 1) activeLenses.delete(key); // always keep one lens on
        } else activeLenses.add(key);
        applyLenses();
      }),
    );
    applyLenses();

    // Hover previews (faint ring, transient); click pins (solid ring, persistent).
    const redrawSel = () => {
      field.redraw();
      hrView.redraw();
      updateCard(hoverId ?? store.getView().selectedId);
    };
    const setHover = (id: number | null) => {
      if (id === hoverId) return;
      hoverId = id;
      redrawSel();
    };
    const bind = (
      canvas: HTMLCanvasElement,
      pick: (x: number, y: number, w: number, h: number) => number | null,
    ) => {
      const at = (e: PointerEvent) => {
        const r = canvas.getBoundingClientRect();
        return pick(e.clientX - r.left, e.clientY - r.top, r.width, r.height);
      };
      let downX = 0;
      let downY = 0;
      canvas.addEventListener("pointermove", (e) => {
        if (e.buttons !== 0) return; // a drag is an orbit/pan, not a hover
        setHover(at(e));
      });
      canvas.addEventListener("pointerleave", () => setHover(null));
      canvas.addEventListener("pointerdown", (e) => {
        downX = e.clientX;
        downY = e.clientY;
      });
      canvas.addEventListener("pointerup", (e) => {
        if (Math.hypot(e.clientX - downX, e.clientY - downY) > 5) return; // that was a drag
        store.setView({ selectedId: at(e) }); // pin (or clear on empty space)
        redrawSel();
      });
    };
    bind(fieldCanvas, (x, y, w, h) => pickStar(rm, x, y, w, h, camera));
    bind(hrCanvas, (x, y, w, h) => pickHRPoint(hr, x, y, w, h));

    const setV = (host: HTMLElement, key: string, val: string) => {
      const el = host.querySelector<HTMLElement>(`[data-v="${key}"]`);
      if (el) el.textContent = val;
    };

    function updateCard(id: number | null) {
      const s = id == null ? null : latent.find((p) => p.id === id);
      if (!s) {
        card.hidden = true;
        return;
      }
      const st = star(s.mass, s.Z, store.getView().t);
      card.hidden = false;
      const sw = card.querySelector<HTMLElement>("[data-swatch]");
      if (sw) {
        const col = `rgb(${st.color.map((c) => Math.round(c * 255)).join(",")})`;
        sw.style.background = col;
        sw.style.color = col; // box-shadow glow uses currentColor
      }
      setV(card, "mass", s.mass.toFixed(2));
      setV(card, "type", st.phase === "remnant" ? "—" : st.spectralType);
      setV(card, "teff", st.Teff ? Math.round(st.Teff).toLocaleString() : "—");
      setV(card, "logl", st.L > 0 ? Math.log10(st.L).toFixed(2) : "—");
      setV(card, "radius", st.R ? st.R.toFixed(2) : "—");
      setV(card, "phase", st.phase === "remnant" ? `remnant · ${st.remnant}` : "main sequence");
    }

    function updateSummary() {
      setV(summary, "n", latent.length.toLocaleString());
      setV(summary, "o", String(latent.filter((s) => s.mass >= 16).length));
      setV(summary, "heaviest", latent.reduce((mx, s) => Math.max(mx, s.mass), 0).toFixed(1));
      const sorted = latent.map((s) => s.mass).sort((a, b) => a - b);
      const median = sorted.length ? sorted[Math.floor(sorted.length / 2)] : 0;
      setV(summary, "median", median.toFixed(2));
      const total = latent.reduce((t, s) => t + s.mass, 0);
      setV(summary, "total", total.toLocaleString(undefined, { maximumFractionDigits: 0 }));
    }

    updateSummary();
  }
</script>

