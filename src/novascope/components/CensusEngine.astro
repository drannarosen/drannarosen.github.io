---
/*
 * CensusEngine.astro — the first novascope engine (Layer 3). Four panels in two
 * rows: top, the cluster (2-D or orbitable 3-D) and its H–R diagram; bottom, the
 * controls and the live IMF histogram — the distribution you're dragging, right
 * next to the slider that shapes it. All physics comes from star() via the
 * selectors; this file is glue + chrome. Styled with --xpl-* tokens (site
 * fallbacks); the style block is global because the readout card is injected
 * client-side and would miss Astro-scoped selectors.
 */
---

<div class="xpl-census" data-census>
  <div class="xpl-census__grid">
    <figure class="xpl-census__panel">
      <figcaption>
        The cluster
        <span class="xpl-census__modes" role="group" aria-label="Cluster view">
          <button type="button" data-mode="2D" class="is-active">2D</button>
          <button type="button" data-mode="3D">3D</button>
        </span>
      </figcaption>
      <canvas data-field aria-label="Star cluster; hover a star to inspect it, drag to orbit in 3D"></canvas>
      <small class="xpl-census__hint" data-hint></small>
    </figure>

    <figure class="xpl-census__panel xpl-census__panel--hr">
      <figcaption>H–R diagram <span>luminosity vs temperature</span></figcaption>
      <canvas data-hr aria-label="Hertzsprung-Russell diagram of the cluster; hover to preview, click to pin"></canvas>
      <aside class="xpl-census__card" data-card hidden></aside>
    </figure>

    <div class="xpl-census__panel xpl-census__panel--pad">
      <div class="xpl-census__controls">
        <label class="xpl-census__ctrl">
          <span>high-mass slope α = <output data-slope-val>2.3</output></span>
          <input type="range" data-slope min="1.5" max="3" step="0.1" value="2.3" />
          <small>top-heavy ← → bottom-heavy</small>
        </label>
        <label class="xpl-census__ctrl">
          <span>stars N = <output data-count-val>1200</output></span>
          <input type="range" data-count min="1.301" max="4.301" step="0.01" value="3.079" />
          <small>watch the rare massive tail flicker</small>
        </label>
        <button type="button" class="xpl-census__reseed" data-reseed>↻ new draw</button>
      </div>
      <p class="xpl-census__summary" data-summary aria-live="polite"></p>
    </div>

    <figure class="xpl-census__panel">
      <figcaption>The IMF <span>sampled bars vs Maschberger law</span></figcaption>
      <canvas data-imf aria-label="Initial mass function: sampled counts against the analytic law"></canvas>
    </figure>
  </div>

  <noscript>
    <p class="xpl-census__noscript">
      This interactive samples and renders a star cluster in your browser — enable
      JavaScript to explore it. The surrounding text explains what it shows.
    </p>
  </noscript>
</div>

<script>
  import { createClusterStore, toRenderModel, toHRModel, toIMFHistogram, localStorageAdapter } from "../state/index.ts";
  import { defaultIdentity, sampleCluster, type ClusterIdentity } from "../core/cluster/index.ts";
  import { star } from "../core/stellar/index.ts";
  import { mountCanvas, makeCamera, attachOrbit, renderClusterField, pickStar, renderHR, pickHRPoint, renderHistogram } from "../viz/index.ts";

  const root = document.querySelector<HTMLElement>("[data-census]");
  if (root) {
    const $ = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const fieldCanvas = $<HTMLCanvasElement>("[data-field]");
    const hrCanvas = $<HTMLCanvasElement>("[data-hr]");
    const imfCanvas = $<HTMLCanvasElement>("[data-imf]");
    const slope = $<HTMLInputElement>("[data-slope]");
    const slopeVal = $<HTMLOutputElement>("[data-slope-val]");
    const count = $<HTMLInputElement>("[data-count]");
    const countVal = $<HTMLOutputElement>("[data-count-val]");
    const card = $<HTMLElement>("[data-card]");
    const summary = $<HTMLElement>("[data-summary]");
    const hint = $<HTMLElement>("[data-hint]");

    const store = createClusterStore({
      adapter: localStorageAdapter(),
      instance: "census",
      identity: defaultIdentity({ sampling: { mode: "count", target: 1200 }, imf: { mMin: 0.1, mMax: 100, alphaHigh: 2.3 } }),
    });

    const camera = makeCamera(store.getView().toggles.threeD ? "3D" : "2D");

    let latent = sampleCluster(store.getIdentity());
    let rm = toRenderModel(latent, store.getView());
    let hr = toHRModel(latent, store.getView());
    let imf = toIMFHistogram(latent, store.getIdentity());

    // Sync controls to the (possibly restored) identity.
    const idNow = store.getIdentity();
    slope.value = String(idNow.imf.alphaHigh);
    slopeVal.value = idNow.imf.alphaHigh.toFixed(1);
    count.value = String(Math.log10(idNow.sampling.target));
    countVal.value = idNow.sampling.target.toLocaleString();

    let hoverId: number | null = null; // transient preview; pinned lives in the store

    const field = mountCanvas(fieldCanvas, (ctx, w, h) =>
      renderClusterField(ctx, rm, w, h, { camera, selectedId: store.getView().selectedId, hoverId }),
    );
    const hrView = mountCanvas(hrCanvas, (ctx, w, h) =>
      renderHR(ctx, hr, w, h, { selectedId: store.getView().selectedId, hoverId }),
    );
    const imfView = mountCanvas(imfCanvas, (ctx, w, h) => renderHistogram(ctx, imf, w, h));

    attachOrbit(fieldCanvas, camera, () => field.redraw());

    function recompute() {
      rm = toRenderModel(latent, store.getView());
      hr = toHRModel(latent, store.getView());
      imf = toIMFHistogram(latent, store.getIdentity());
      field.redraw();
      hrView.redraw();
      imfView.redraw();
      updateSummary();
      updateCard(hoverId ?? store.getView().selectedId);
    }
    function patchIdentity(patch: Partial<ClusterIdentity>) {
      store.setIdentity({ ...store.getIdentity(), ...patch });
      latent = sampleCluster(store.getIdentity());
      recompute();
    }

    slope.addEventListener("input", () => {
      const a = Number(slope.value);
      slopeVal.value = a.toFixed(1);
      patchIdentity({ imf: { ...store.getIdentity().imf, alphaHigh: a } });
    });
    count.addEventListener("input", () => {
      const n = Math.round(10 ** Number(count.value));
      countVal.value = n.toLocaleString();
      patchIdentity({ sampling: { mode: "count", target: n } });
    });
    $<HTMLButtonElement>("[data-reseed]").addEventListener("click", () => {
      patchIdentity({ seed: (store.getIdentity().seed * 1103515245 + 12345) >>> 0 });
    });

    // 2-D / 3-D toggle.
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const setMode = (mode: "2D" | "3D") => {
      camera.mode = mode;
      camera.yaw = mode === "3D" ? 0.5 : 0;
      camera.pitch = mode === "3D" ? 0.35 : 0;
      camera.zoom = 1;
      camera.panX = 0;
      camera.panY = 0;
      store.setView({ toggles: { ...store.getView().toggles, threeD: mode === "3D" } });
      modeBtns.forEach((b) => b.classList.toggle("is-active", b.dataset.mode === mode));
      hint.textContent = mode === "3D" ? "drag to orbit · scroll to zoom · shift-drag to pan" : "scroll to zoom · drag to pan";
      field.redraw();
    };
    modeBtns.forEach((b) => b.addEventListener("click", () => setMode(b.dataset.mode as "2D" | "3D")));
    setMode(camera.mode);

    // Hover previews (faint ring, transient); click pins (solid ring, persistent).
    const redrawSel = () => {
      field.redraw();
      hrView.redraw();
      updateCard(hoverId ?? store.getView().selectedId);
    };
    const setHover = (id: number | null) => {
      if (id === hoverId) return;
      hoverId = id;
      redrawSel();
    };
    const bind = (
      canvas: HTMLCanvasElement,
      pick: (x: number, y: number, w: number, h: number) => number | null,
    ) => {
      const at = (e: PointerEvent) => {
        const r = canvas.getBoundingClientRect();
        return pick(e.clientX - r.left, e.clientY - r.top, r.width, r.height);
      };
      let downX = 0;
      let downY = 0;
      canvas.addEventListener("pointermove", (e) => {
        if (e.buttons !== 0) return; // a drag is an orbit/pan, not a hover
        setHover(at(e));
      });
      canvas.addEventListener("pointerleave", () => setHover(null));
      canvas.addEventListener("pointerdown", (e) => {
        downX = e.clientX;
        downY = e.clientY;
      });
      canvas.addEventListener("pointerup", (e) => {
        if (Math.hypot(e.clientX - downX, e.clientY - downY) > 5) return; // that was a drag
        store.setView({ selectedId: at(e) }); // pin (or clear on empty space)
        redrawSel();
      });
    };
    bind(fieldCanvas, (x, y, w, h) => pickStar(rm, x, y, w, h, camera));
    bind(hrCanvas, (x, y, w, h) => pickHRPoint(hr, x, y, w, h));

    function updateCard(id: number | null) {
      const s = id == null ? null : latent.find((p) => p.id === id);
      if (!s) {
        card.hidden = true;
        return;
      }
      const st = star(s.mass, s.Z, store.getView().t);
      const phase = st.phase === "remnant" ? `remnant · ${st.remnant}` : "main sequence";
      card.hidden = false;
      card.innerHTML = `
        <span class="xpl-census__swatch" style="background:rgb(${st.color.map((c) => Math.round(c * 255)).join(",")})"></span>
        <dl>
          <div><dt>mass</dt><dd>${s.mass.toFixed(2)} M<sub>☉</sub></dd></div>
          <div><dt>type</dt><dd>${st.phase === "remnant" ? "—" : st.spectralType}</dd></div>
          <div><dt>T<sub>eff</sub></dt><dd>${st.Teff ? Math.round(st.Teff).toLocaleString() + " K" : "—"}</dd></div>
          <div><dt>luminosity</dt><dd>${fmtL(st.L)}</dd></div>
          <div><dt>radius</dt><dd>${st.R ? st.R.toFixed(2) + " R☉" : "—"}</dd></div>
          <div><dt>phase</dt><dd>${phase}</dd></div>
        </dl>`;
    }

    function updateSummary() {
      const n = latent.length;
      const oStars = latent.filter((s) => s.mass >= 16).length;
      const heaviest = latent.reduce((m, s) => Math.max(m, s.mass), 0);
      summary.textContent = `${n.toLocaleString()} stars · ${oStars} O-type (≥16 M☉) · heaviest ${heaviest.toFixed(1)} M☉`;
    }

    function fmtL(L: number): string {
      if (!L) return "—";
      if (L >= 1e4 || L < 1e-2) {
        const e = Math.floor(Math.log10(L));
        return `${(L / 10 ** e).toFixed(1)}×10${sup(e)} L☉`;
      }
      return `${L.toFixed(L < 10 ? 2 : 0)} L☉`;
    }
    function sup(n: number): string {
      const m: Record<string, string> = { "-": "⁻", "0": "⁰", "1": "¹", "2": "²", "3": "³", "4": "⁴", "5": "⁵", "6": "⁶", "7": "⁷", "8": "⁸", "9": "⁹" };
      return String(n).split("").map((c) => m[c] ?? c).join("");
    }

    updateSummary();
  }
</script>

<style is:global>
  /* Global (not Astro-scoped) because the readout card's contents are injected
   * client-side via innerHTML and would miss scoped selectors. Every rule is
   * .xpl-census*-prefixed, so nothing leaks — and this is how the styles ship
   * once the component is extracted as a package anyway. */
  .xpl-census {
    --xpl-ink: var(--ink, #e8e8ea);
    --xpl-dim: var(--ink-dim, #9aa0aa);
    --xpl-teal: var(--spec-teal-bright, #4fd1c5);
    --xpl-rose: var(--spec-rose-bright, #f472b6);
    --xpl-border: var(--border, #2a2c31);
    --xpl-panel: var(--surface-1, #14151a);
    display: grid;
    gap: var(--space-m, 1rem);
    max-inline-size: 76rem; /* caps the top row into near-squares on wide screens */
    margin-inline: auto;
  }
  .xpl-census__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m, 1rem);
    align-items: start;
  }
  @media (max-width: 46rem) {
    .xpl-census__grid { grid-template-columns: 1fr; }
  }
  .xpl-census__panel {
    margin: 0;
    border: 1px solid var(--xpl-border);
    border-radius: var(--radius, 10px);
    background: radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--xpl-panel) 92%, black), #0a0b0e);
    overflow: hidden;
  }
  .xpl-census__panel--pad { padding: var(--space-s, 0.75rem); display: grid; gap: var(--space-s, 0.75rem); align-content: start; background: var(--xpl-panel); }
  .xpl-census__panel figcaption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2xs, 0.4rem) var(--space-s, 0.75rem);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--step--1, 0.85rem);
    color: var(--xpl-ink);
    border-bottom: 1px solid var(--xpl-border);
  }
  .xpl-census__panel figcaption > span { color: var(--xpl-dim); font-size: var(--step--2, 0.75rem); }
  .xpl-census__panel canvas { display: block; inline-size: 100%; touch-action: none; }
  /* Square viewscreens for the two main plots; the cap on .xpl-census keeps them
   * from ballooning on very wide screens. */
  .xpl-census__panel [data-field], .xpl-census__panel [data-hr] { aspect-ratio: 1; block-size: auto; cursor: crosshair; }
  /* IMF: less wide, a bit taller — a 4:3 box, centred in its cell. */
  .xpl-census__panel [data-imf] { aspect-ratio: 4 / 3; block-size: auto; max-inline-size: 26rem; margin-inline: auto; }
  .xpl-census__panel--hr { position: relative; }
  .xpl-census__hint { display: block; padding: 0 var(--space-s, 0.75rem) var(--space-2xs, 0.4rem); font-family: var(--font-mono, ui-monospace, monospace); font-size: var(--step--2, 0.72rem); color: var(--xpl-dim); }

  .xpl-census__modes { display: inline-flex; gap: 2px; }
  .xpl-census__modes button {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--step--2, 0.72rem);
    color: var(--xpl-dim);
    background: transparent;
    border: 1px solid var(--xpl-border);
    padding: 1px 8px;
    cursor: pointer;
  }
  .xpl-census__modes button:first-child { border-radius: 999px 0 0 999px; }
  .xpl-census__modes button:last-child { border-radius: 0 999px 999px 0; }
  .xpl-census__modes button.is-active { color: #0a0b0e; background: var(--xpl-teal); border-color: var(--xpl-teal); }

  .xpl-census__controls { display: grid; gap: var(--space-s, 0.75rem); }
  .xpl-census__ctrl {
    display: grid;
    gap: 0.25rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--step--1, 0.85rem);
    color: var(--xpl-ink);
  }
  .xpl-census__ctrl { max-inline-size: 16rem; }
  .xpl-census__ctrl output { color: var(--xpl-teal); }
  .xpl-census__ctrl small { color: var(--xpl-dim); font-size: var(--step--2, 0.72rem); }
  .xpl-census__ctrl input[type="range"] { accent-color: var(--xpl-rose); inline-size: 100%; }
  .xpl-census__reseed {
    justify-self: start;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--step--1, 0.85rem);
    color: var(--xpl-ink);
    background: transparent;
    border: 1px solid var(--xpl-border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .xpl-census__reseed:hover { border-color: var(--xpl-teal); }
  .xpl-census__summary { font-family: var(--font-mono, ui-monospace, monospace); font-size: var(--step--1, 0.85rem); color: var(--xpl-dim); margin: 0; }
  /* Docked to the HR panel's empty upper-right corner as a compact HUD readout,
   * so a selected star's properties sit right beside the diagram. Built to
   * relocate to an under-canvas strip when stellar tracks add time-dependent
   * readouts (just change these position rules). */
  .xpl-census__panel--hr .xpl-census__card {
    position: absolute;
    inset-block-start: 2.7rem;
    inset-inline-end: 0.55rem;
    z-index: 2;
    display: flex;
    gap: var(--space-xs, 0.6rem);
    align-items: start;
    max-inline-size: 15rem;
    padding: var(--space-2xs, 0.5rem) var(--space-s, 0.7rem);
    border: 1px solid color-mix(in srgb, var(--xpl-teal) 30%, var(--xpl-border));
    border-radius: var(--radius, 10px);
    background: color-mix(in srgb, var(--xpl-panel) 92%, black);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
  }
  .xpl-census__swatch { flex: none; inline-size: 1.4rem; block-size: 1.4rem; border-radius: 50%; box-shadow: 0 0 12px currentColor; margin-block-start: 0.15rem; }
  .xpl-census__card dl { display: grid; gap: 0.2rem; margin: 0; flex: 1; }
  .xpl-census__card dl > div { display: flex; justify-content: space-between; align-items: baseline; gap: 1.2rem; }
  .xpl-census__card dt { color: var(--xpl-dim); font-family: var(--font-mono, ui-monospace, monospace); font-size: var(--step--2, 0.75rem); }
  .xpl-census__card dd { margin: 0; color: var(--xpl-ink); font-size: var(--step--1, 0.85rem); }
  .xpl-census__noscript { color: var(--xpl-dim); font-size: var(--step--1, 0.85rem); }
</style>
