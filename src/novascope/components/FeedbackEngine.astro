---
/*
 * FeedbackEngine — the /explore/feedback-budget explorable.
 *
 * Renders a gravoturb cluster and, beside it, the feedback ACCOUNTING: two
 * ratio bars (momentum delivered vs the gas threshold, energy vs binding), the
 * two-stage gas-expulsion verdict, and (collapsed) the per-channel
 * momentum-vs-time plot.
 *
 * Two deliberately SEPARATE axes: the scrub is expulsion PROGRESS (embedded →
 * cleared) driving the outward gas render (setExpel), because the gas physically
 * clears in the first ~10% of the window and time would make a blink-and-miss
 * animation. The real-time story -- how fast, which channel leads -- lives in
 * the plot, with t_remove marked. The bars and verdict are the accounting the
 * spectacle exists to make legible.
 *
 * Data flow: viz/loadScene + createEngine render the cloud; state/feedback runs
 * the Layer-0 budget. The two share the browser-cached fetches but nothing else,
 * keeping the import boundary intact.
 */
import PresentFrame from "../../components/explore/PresentFrame.astro";
import RatioBar from "./RatioBar.astro";
---

<div class="fbe" data-fbe>
  <PresentFrame
    label="A star cluster and its feedback budget"
    hint="drag to rotate · scroll to zoom · ←/→ scrubs time · space plays · F fullscreen"
  >
    <canvas slot="stage" data-cluster aria-label="A young star cluster embedded in its natal gas."></canvas>

    <div slot="controls" class="fbe__controls">
      <div class="fbe__toolbar">
        <div class="fbe__pills" data-realizations role="group" aria-label="Choose an environment">
          <!-- realization pills injected from the manifest -->
        </div>
        <button type="button" class="fbe__action is-active" data-play aria-pressed="true">❙❙ pause</button>
      </div>

      <label class="fbe__scrub">
        <span class="fbe__scrub-head">
          <span class="fbe__scrub-name">Expulsion</span>
          <span class="fbe__cleared" data-cleared>embedded</span>
          <span class="fbe__endpts">embedded → cleared</span>
        </span>
        <input type="range" min="0" max="1" step="0.005" value="0" autocomplete="off" data-scrub />
      </label>

      <div class="fbe__channels" role="group" aria-label="Feedback channels — turn off to see each contribution">
        <span class="fbe__channels-lead">channels</span>
        <button type="button" class="fbe__chip is-active" data-ch="winds" aria-pressed="true">winds</button>
        <button type="button" class="fbe__chip is-active" data-ch="photoionization" aria-pressed="true">H II</button>
        <button type="button" class="fbe__chip is-active" data-ch="radiation" aria-pressed="true">radiation</button>
      </div>

      <p class="fbe__status" data-status aria-live="polite">Loading cluster…</p>
    </div>
  </PresentFrame>

  <div class="fbe__panel">
    <div class="fbe__verdict" data-verdict>
      <p class="fbe__stage fbe__stage--1" data-stage1>—</p>
      <p class="fbe__stage fbe__stage--2" data-stage2>—</p>
    </div>

    <div class="fbe__bars">
      <RatioBar
        id="momentum"
        label="Momentum delivered"
        thresholdLabel="expel the gas"
        ariaLabel="Feedback momentum delivered, relative to the momentum needed to expel the residual gas."
      />
      <RatioBar
        id="energy"
        label="Energy retained"
        thresholdLabel="unbind"
        ariaLabel="Feedback energy retained, relative to the cloud's binding energy."
      />
    </div>

    <details class="fbe__more">
      <summary>components over time</summary>
      <figure class="fbe__plot">
        <svg data-plot viewBox="0 0 340 170" preserveAspectRatio="xMidYMid meet" role="img"
          aria-label="Momentum delivered by each feedback channel versus time.">
        </svg>
        <figcaption class="fbe__legend" data-legend></figcaption>
      </figure>
      <dl class="fbe__nums" data-nums></dl>
    </details>
  </div>
</div>

<script>
  import { loadScene, createEngine, attachInteraction } from "../../lib/cluster";
  import { loadFeedbackRealization, recomputeFeedback, type FeedbackRealization }
    from "../state/feedback";

  const root = document.querySelector<HTMLElement>("[data-fbe]");
  if (root) void mount(root);

  type Ch = "winds" | "photoionization" | "radiation";
  const CH_COLORS: Record<Ch | "total", string> = {
    winds: "#9ab8ff", photoionization: "#4fd6c4", radiation: "#f3c95a", total: "#f7f3e2",
  };

  /** Fill fraction for a ratio: threshold (1) sits at 0.62; above it log-compresses. */
  function ratioFill(r: number): number {
    if (r <= 0) return 0;
    if (r <= 1) return 0.62 * r;
    return 0.62 + 0.38 * Math.min(1, Math.log10(r) / Math.log10(12));
  }
  function ratioState(r: number): "bound" | "marginal" | "blow-out" {
    return r >= 1.2 ? "blow-out" : r <= 0.8 ? "bound" : "marginal";
  }
  const fmt = (x: number, d = 1) =>
    x >= 1e4 ? x.toExponential(1) : x.toLocaleString("en-US", { maximumFractionDigits: d });

  async function mount(el: HTMLElement) {
    const canvas = el.querySelector<HTMLCanvasElement>("[data-cluster]")!;
    const status = el.querySelector<HTMLElement>("[data-status]")!;
    const scrub = el.querySelector<HTMLInputElement>("[data-scrub]")!;
    const play = el.querySelector<HTMLButtonElement>("[data-play]")!;
    const clearedOut = el.querySelector<HTMLElement>("[data-cleared]")!;
    const frame = el.querySelector<HTMLElement>("[data-present]");

    let engine: ReturnType<typeof createEngine> | null = null;
    let fb: FeedbackRealization | null = null;
    let raf = 0;
    let playing = true;

    const setPlaying = (on: boolean) => {
      playing = on;
      play.classList.toggle("is-active", on);
      play.setAttribute("aria-pressed", String(on));
      play.textContent = on ? "❙❙ pause" : "▸ play";
    };
    play.addEventListener("click", () => setPlaying(!playing));

    // ── realization picker from the manifest (labels never retyped) ──
    const manifest = await fetch("/data/gravoturb/manifest.json").then((r) => r.json());
    const picker = el.querySelector<HTMLElement>("[data-realizations]")!;
    for (const r of manifest.realizations as { label: string; path: string }[]) {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "fbe__pill";
      b.textContent = r.label;
      b.dataset.path = r.path;
      b.setAttribute("aria-pressed", "false");
      b.addEventListener("click", () => void select(r.path));
      picker.appendChild(b);
    }

    const enabled = (): Record<Ch, boolean> => {
      const on = {} as Record<Ch, boolean>;
      for (const c of el.querySelectorAll<HTMLButtonElement>("[data-ch]"))
        on[c.dataset.ch as Ch] = c.classList.contains("is-active");
      return on;
    };

    async function select(path: string) {
      for (const b of picker.querySelectorAll<HTMLButtonElement>(".fbe__pill")) {
        const on = b.dataset.path === path;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-pressed", String(on));
      }
      status.textContent = "Loading…";
      const name = path === "/data/gravoturb" ? undefined : path.split("/").pop();
      const [scene, budget] = await Promise.all([
        loadScene(path),
        loadFeedbackRealization(name, { enabled: enabled() }),
      ]);
      engine?.cleanup();
      engine = createEngine(canvas, scene, { emphasizeHot: true });
      attachInteraction(canvas, engine);
      fb = budget;
      renderBudget();
      applyScrub(+scrub.value);
      if (engine.reducedMotion) { setPlaying(false); play.disabled = true; }
      status.textContent =
        `${fmt(budget.meta.n_stars as number, 0)} stars · budget is an accounting tool, not a hydro sim`;
    }

    // ── the budget readouts (bars, verdict, plot, numbers) ──
    function renderBudget() {
      if (!fb) return;
      const L = fb.ledger, g = L.gasExpulsion;
      setBar(el, "momentum", g.gasMomentumRatio);
      setBar(el, "energy", L.energyRatio);
      // stage 1
      const s1 = el.querySelector<HTMLElement>("[data-stage1]")!;
      s1.textContent = g.gasExpelled
        ? `Gas expelled — momentum ${g.gasMomentumRatio.toFixed(1)}× the threshold, ${g.removalRegime} removal`
        : `Gas retained — only ${(g.gasMomentumRatio * 100).toFixed(0)}% of the momentum needed; cluster stays embedded`;
      // stage 2
      const s2 = el.querySelector<HTMLElement>("[data-stage2]")!;
      s2.textContent = g.gasExpelled
        ? `Cluster ${g.survivalLabel} — q = ${g.qVirialPost.toFixed(3)} after expulsion (bound below 1): born dynamically cold`
        : `Survival moot while the gas stays`;
      s2.dataset.fate = g.survivalLabel;
      drawPlot(el, fb);
      renderNums(el, fb);
    }

    // The scrub is EXPULSION PROGRESS (0 = embedded, 1 = cleared), not time --
    // the gas clears in the first ~11% of the pre-SN window, so time is a poor
    // scrub axis (the animation would finish in a blink). setExpel balloons the
    // gas OUTWARD (homologous stand-in) so the cluster emerges. The real-time
    // story -- how FAST this happens -- lives in the components plot, with
    // t_remove marked. Two honest axes, deliberately decoupled.
    function applyScrub(frac: number) {
      if (!engine) return;
      engine.setExpel(frac);
      clearedOut.textContent =
        frac <= 0.01 ? "embedded" : frac >= 0.99 ? "gas cleared" : `gas ${Math.round(frac * 100)}% expelled`;
    }

    // ── controls ──
    scrub.addEventListener("input", () => { setPlaying(false); applyScrub(+scrub.value); });
    for (const c of el.querySelectorAll<HTMLButtonElement>("[data-ch]"))
      c.addEventListener("click", () => {
        const on = !c.classList.contains("is-active");
        c.classList.toggle("is-active", on);
        c.setAttribute("aria-pressed", String(on));
        if (!fb) return;
        fb = recomputeFeedback(fb, { enabled: enabled() });
        renderBudget();
      });
    frame?.addEventListener("present:next", () => {
      setPlaying(false); scrub.value = String(Math.min(1, +scrub.value + 0.04)); applyScrub(+scrub.value);
    });
    frame?.addEventListener("present:prev", () => {
      setPlaying(false); scrub.value = String(Math.max(0, +scrub.value - 0.04)); applyScrub(+scrub.value);
    });
    frame?.addEventListener("present:reset", () => { scrub.value = "0"; applyScrub(0); });

    // ── play loop (respects reduced motion via engine.reducedMotion) ──
    let last = 0;
    function tick(ts: number) {
      raf = requestAnimationFrame(tick);
      if (!playing) { last = ts; return; }
      const dt = last ? (ts - last) / 1000 : 0; last = ts;
      let v = +scrub.value + dt / 6; // ~6 s sweep
      if (v >= 1) v = 0;
      scrub.value = String(v);
      applyScrub(v);
    }
    raf = requestAnimationFrame(tick);
    window.addEventListener("beforeunload", () => { cancelAnimationFrame(raf); engine?.cleanup(); });

    await select("/data/gravoturb"); // default: the Orion-like fiducial
  }

  // ── small DOM helpers ──
  function setBar(el: HTMLElement, id: string, ratio: number) {
    const bar = el.querySelector<HTMLElement>(`[data-ratiobar="${id}"]`);
    if (!bar) return;
    bar.dataset.state = ratioState(ratio);
    bar.querySelector<HTMLElement>("[data-ratiobar-fill]")!.style.inlineSize =
      `${(ratioFill(ratio) * 100).toFixed(1)}%`;
    bar.querySelector<HTMLElement>("[data-ratiobar-value]")!.textContent = `${ratio.toFixed(2)}×`;
  }

  function renderNums(el: HTMLElement, fb: FeedbackRealization) {
    const L = fb.ledger, m = fb.meta;
    const rows: [string, string][] = [
      ["window", `${L.windowMyr.toFixed(2)} Myr`],
      ["Σ", `${(m.env_sigma_msun_pc2 as number).toFixed(0)} M⊙/pc²`],
      ["ψ", L.diagnostics.radiation.psi.toFixed(2)],
      ["r_ch", `${L.diagnostics.radiation.rCh.toFixed(2)} pc`],
      ["M_gas", `${fmt(L.gasExpulsion.mGas)} M⊙`],
    ];
    el.querySelector<HTMLElement>("[data-nums]")!.innerHTML = rows
      .map(([k, v]) => `<div><dt>${k}</dt><dd>${v}</dd></div>`).join("");
  }

  // ── the momentum-vs-time plot (pure SVG from the trajectory) ──
  const PW = 340, PH = 170, PAD = 26;
  function scaleX(t: number, win: number) { return PAD + (t / win) * (PW - PAD - 6); }
  function scaleY(p: number, pmax: number) { return PH - PAD - (p / pmax) * (PH - PAD - 10); }

  function drawPlot(el: HTMLElement, fb: FeedbackRealization) {
    const svg = el.querySelector<SVGSVGElement>("[data-plot]")!;
    const tr = fb.trajectory;
    const win = tr.windowMyr || 1;
    const pmax = Math.max(tr.gasMomentumNeeded, ...tr.totalMomentum) * 1.08 || 1;
    const line = (ys: number[], color: string, w = 1.5) =>
      `<polyline fill="none" stroke="${color}" stroke-width="${w}" points="${
        tr.tMyr.map((t, i) => `${scaleX(t, win).toFixed(1)},${scaleY(ys[i]!, pmax).toFixed(1)}`).join(" ")
      }"/>`;
    const yThresh = scaleY(tr.gasMomentumNeeded, pmax);
    const vline = (t: number, color: string, dash: string, label: string) => {
      if (!isFinite(t) || t <= 0 || t > win) return "";
      const x = scaleX(t, win);
      return `<line x1="${x.toFixed(1)}" y1="8" x2="${x.toFixed(1)}" y2="${PH - PAD}" stroke="${color}" stroke-width="1" stroke-dasharray="${dash}" opacity="0.7"/>`
        + `<text x="${(x + 2).toFixed(1)}" y="16" fill="${color}" font-size="8" font-family="monospace">${label}</text>`;
    };
    svg.innerHTML =
      `<line x1="${PAD}" y1="${PH - PAD}" x2="${PW - 6}" y2="${PH - PAD}" stroke="currentColor" stroke-width="1" opacity="0.4"/>`
      + `<line x1="${PAD}" y1="8" x2="${PAD}" y2="${PH - PAD}" stroke="currentColor" stroke-width="1" opacity="0.4"/>`
      + `<line x1="${PAD}" y1="${yThresh.toFixed(1)}" x2="${PW - 6}" y2="${yThresh.toFixed(1)}" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" opacity="0.55"/>`
      + `<text x="${PW - 8}" y="${(yThresh - 3).toFixed(1)}" text-anchor="end" fill="currentColor" font-size="8" font-family="monospace" opacity="0.7">gas threshold</text>`
      + vline(tr.tCrossMyr, "#c98", "2 2", "t_cross")
      + vline(tr.tRemoveMyr, "#8c8", "2 2", "t_remove")
      + line(tr.windMomentum, CH_COLORS.winds)
      + line(tr.hiiMomentum, CH_COLORS.photoionization)
      + line(tr.radMomentum, CH_COLORS.radiation)
      + line(tr.totalMomentum, CH_COLORS.total, 2)
      + `<text x="${PAD}" y="${PH - 8}" fill="currentColor" font-size="8" font-family="monospace" opacity="0.6">0</text>`
      + `<text x="${PW - 6}" y="${PH - 8}" text-anchor="end" fill="currentColor" font-size="8" font-family="monospace" opacity="0.6">${win.toFixed(1)} Myr</text>`;
    el.querySelector<HTMLElement>("[data-legend]")!.innerHTML =
      (["winds", "photoionization", "radiation", "total"] as const)
        .map((c) => `<span style="--c:${CH_COLORS[c]}">${c === "photoionization" ? "H II" : c}</span>`).join("");
  }
</script>

<style is:global>
  /* GLOBAL, not scoped: the realization pills are created client-side (Astro's
   * data-astro-cid is not stamped on runtime nodes, so scoped rules would miss
   * them — the same trap Census documents). Every selector is .fbe*-prefixed, so
   * nothing leaks. Shared visual language with Census: --xpl-* tokens, pill
   * controls (999px, teal-active), and the radial-gradient panel. */
  .fbe {
    --xpl-ink: var(--ink, #e8e8ea);
    --xpl-dim: var(--ink-dim, #9aa0aa);
    --xpl-teal: var(--spec-teal-bright, #4fd1c5);
    --xpl-rose: var(--spec-rose-bright, #f472b6);
    --xpl-border: var(--border, #2a2c31);
    --xpl-panel: var(--surface-1, #14151a);
    display: grid;
    gap: var(--space-l);
    grid-template-columns: 1fr;
  }
  @media (min-width: 60rem) {
    .fbe { grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr); align-items: start; }
  }
  .fbe__controls { display: grid; gap: 0.7rem; }
  .fbe__toolbar { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-s); flex-wrap: wrap; }
  .fbe__pills { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  /* pills + chips share the Census chip recipe */
  .fbe__pill, .fbe__chip, .fbe__action {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: var(--step--2);
    color: var(--xpl-dim);
    background: transparent;
    border: 1px solid var(--xpl-border);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .fbe__pill:hover, .fbe__chip:hover, .fbe__action:hover { color: var(--xpl-ink); border-color: var(--xpl-teal); }
  .fbe__pill.is-active, .fbe__chip.is-active { color: #0a0b0e; background: var(--xpl-teal); border-color: var(--xpl-teal); }
  .fbe__action { color: var(--xpl-ink); white-space: nowrap; }
  .fbe__action.is-active { border-color: var(--xpl-teal); }
  .fbe__action:disabled { opacity: 0.5; cursor: not-allowed; }

  .fbe__scrub { display: grid; gap: 0.3rem; }
  .fbe__scrub-head { display: flex; gap: 0.6em; align-items: baseline; flex-wrap: wrap; font-family: var(--font-mono); font-size: var(--step--2); }
  .fbe__scrub-name { color: var(--xpl-dim); }
  .fbe__cleared { color: var(--xpl-teal); }
  .fbe__endpts { color: var(--xpl-dim); opacity: 0.7; margin-inline-start: auto; }
  .fbe__scrub input[type="range"] { inline-size: 100%; accent-color: var(--xpl-rose); }

  .fbe__channels { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; }
  .fbe__channels-lead { font-family: var(--font-mono); font-size: var(--step--2); color: var(--xpl-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-inline-end: 0.1rem; }
  .fbe__status { font-family: var(--font-mono); font-size: var(--step--3, 0.68rem); color: var(--ink-faint); } /* type-scale-exempt: dense status line */

  .fbe__panel {
    display: grid; gap: var(--space-l); align-content: start;
    padding: var(--space-m);
    border: 1px solid var(--xpl-border);
    border-radius: var(--radius, 10px);
    background: radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--xpl-panel) 92%, black), #0a0b0e);
  }

  /* verdict is the hero: the answer, in plain language, first */
  .fbe__verdict { display: grid; gap: 0.5rem; }
  .fbe__stage { margin: 0; }
  .fbe__stage--1 { font-size: var(--step-1); line-height: 1.3; color: var(--xpl-ink); }
  .fbe__stage--2 { font-size: var(--step--1); line-height: 1.4; color: var(--xpl-dim); }
  .fbe__stage--2[data-fate="dissolves"] { color: var(--spec-amber, #e8a33d); }

  .fbe__bars { display: grid; gap: var(--space-m); }

  /* everything quantitative-but-secondary folds away */
  .fbe__more { border-block-start: 1px solid var(--xpl-border); padding-block-start: var(--space-s); }
  .fbe__more > summary {
    cursor: pointer; font-family: var(--font-mono); font-size: var(--step--2);
    color: var(--xpl-dim); text-transform: uppercase; letter-spacing: 0.05em;
    list-style: none;
  }
  .fbe__more > summary::-webkit-details-marker { display: none; }
  .fbe__more > summary::before { content: "› "; display: inline-block; transition: transform 0.15s; }
  .fbe__more[open] > summary::before { transform: rotate(90deg); }
  .fbe__plot { margin: var(--space-s) 0 0; display: grid; gap: 0.3rem; }
  .fbe__plot svg { inline-size: 100%; block-size: auto; color: var(--xpl-dim); }
  .fbe__legend { display: flex; flex-wrap: wrap; gap: 0.8em; font-family: var(--font-mono); font-size: var(--step--2); color: var(--xpl-dim); }
  .fbe__legend span { display: inline-flex; align-items: center; gap: 0.35em; }
  .fbe__legend span::before { content: ""; inline-size: 10px; block-size: 2px; background: var(--c); border-radius: 2px; }
  .fbe__nums { display: flex; flex-wrap: wrap; gap: 0.6rem 1.1rem; margin: var(--space-s) 0 0; }
  .fbe__nums div { display: grid; }
  .fbe__nums dt { font-family: var(--font-mono); font-size: var(--step--3, 0.68rem); color: var(--ink-faint); } /* type-scale-exempt: compact stat key */
  .fbe__nums dd { font-family: var(--font-mono); font-size: var(--step--1); color: var(--ink); margin: 0; font-variant-numeric: tabular-nums; }
</style>
