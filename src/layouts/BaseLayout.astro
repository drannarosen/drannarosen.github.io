---
import "../styles/global.css";
// KaTeX stylesheet + fonts, self-hosted from the npm package (no CDN — ADR-0007).
import "katex/dist/katex.min.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description: string;
  /** Path for canonical URL, e.g. "/research". Defaults to the current route. */
  path?: string;
  /** Keep the page out of search engines (unlisted dev sandboxes). */
  noindex?: boolean;
  /**
   * Link-preview card, relative to /og/. Anna's distribution is Slack
   * (LSST DA, collaboration channels), where a link with a card gets clicked
   * and a bare URL scrolls past — so this is the highest-leverage metadata on
   * the site. Generated by scripts/og/generate.mjs.
   */
  ogImage?: string;
  /** What the card shows, for readers using a screen reader on the unfurl. */
  ogImageAlt?: string;
  /** "article" for posts; "website" otherwise. */
  ogType?: "website" | "article";
}

const {
  title,
  description,
  path,
  noindex,
  ogImage = "default.png",
  ogImageAlt = "A simulated young star cluster: stars coloured by effective temperature, embedded in turbulent natal gas.",
  ogType = "website",
} = Astro.props;
const canonical = new URL(path ?? Astro.url.pathname, Astro.site).href;
// Unfurlers require an absolute URL; a relative one silently yields no card.
const ogImageUrl = new URL(`/og/${ogImage}`, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical self-hosted fonts to avoid layout shift -->
    <link
      rel="preload"
      href="/fonts/Outfit.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SourceSans3.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content="Anna Rosen" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Anna Rosen, Ph.D." />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="color-scheme" content="dark" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
