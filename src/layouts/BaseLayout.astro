---
import "../styles/global.css";
// KaTeX stylesheet + fonts, self-hosted from the npm package (no CDN — ADR-0011).
import "katex/dist/katex.min.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import StructuredData from "../components/StructuredData.astro";

interface Props {
  title: string;
  description: string;
  /** Path for canonical URL, e.g. "/research". Defaults to the current route. */
  path?: string;
  /** Keep the page out of search engines (unlisted dev sandboxes). */
  noindex?: boolean;
  /**
   * Link-preview card, relative to /og/. Distribution is Slack (LSST DA,
   * collaboration channels), where a link with a card gets clicked and a bare
   * URL scrolls past — so this is the highest-leverage metadata on the site.
   * Open Graph is read by Slack, Bluesky, Mastodon, Discord and mail clients;
   * no Twitter-specific tags, which are a platform this site does not target.
   * Generated by scripts/og/generate.mjs.
   */
  ogImage?: string;
  /** What the card shows, for readers using a screen reader on the unfurl. */
  ogImageAlt?: string;
  /** "article" for posts; "website" otherwise. */
  ogType?: "website" | "article";
  /** JSON-LD for a post; omitted elsewhere, where the Person graph is used. */
  article?: {
    headline: string;
    description: string;
    datePublished: Date;
    url: string;
    image?: string;
    humanAuthored: boolean;
  };
}

const {
  title,
  description,
  path,
  noindex,
  ogImage = "default.png",
  ogImageAlt = "A simulated young star cluster: stars coloured by effective temperature, embedded in turbulent natal gas.",
  ogType = "website",
  article,
} = Astro.props;
const canonical = new URL(path ?? Astro.url.pathname, Astro.site).href;
// Unfurlers require an absolute URL; a relative one silently yields no card.
const ogImageUrl = new URL(`/og/${ogImage}`, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google Analytics (gtag.js), G-50FCCTYBRH.
        It lives HERE, in the one layout every page uses, rather than being
        pasted into each page as Google's instructions describe: that is what
        makes "no more than one Google tag per page" structurally true instead
        of a rule someone has to remember. A new page gets it by using this
        layout; nothing to add.

        PROD ONLY, same as the Cloudflare beacon: loading it from `pnpm dev`
        would file local page views as real traffic and pollute the reports. */}
    {import.meta.env.PROD && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-50FCCTYBRH" />
        <script
          is:inline
          set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-50FCCTYBRH');`}
        />
      </>
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical self-hosted fonts to avoid layout shift -->
    <link
      rel="preload"
      href="/fonts/Outfit.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SourceSans3.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* The astrobytes feed is advertised site-wide; the /now feed only on /now,
        so a reader's "subscribe" button offers the feed for the page they are
        on rather than always the posts. */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Astrobytes — Anna Rosen"
      href="/astrobytes/rss.xml"
    />
    {
      path === "/now" && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title="Now — Anna Rosen"
          href="/now/rss.xml"
        />
      )
    }
    <meta name="author" content="Anna Rosen" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Anna Rosen, Ph.D." />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="color-scheme" content="dark" />

    {/* Structured data is suppressed on unlisted sandboxes: nothing there
        should be advertised to an aggregator. */}
    {!noindex && <StructuredData kind={article ? "article" : "person"} article={article} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />

    {/* Cloudflare Web Analytics (ADR-0011). The only third-party request the
        site makes. Cookieless and without fingerprinting, so it does not
        reintroduce the tracking ADR-0007 existed to prevent.

        PROD ONLY: loading it from `pnpm dev` would file every local page view
        as real traffic and put a third-party request in the dev environment.

        The JS beacon rather than Cloudflare's automatic injection, because the
        DNS records are deliberately DNS-only (grey cloud) and auto-injection
        requires proxying. */}
    {import.meta.env.PROD && (
      <script
        is:inline
        type="module"
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon='{"token": "f01db47450674d3cb0f1f81e19433790"}'
      />
    )}
  </body>
</html>
