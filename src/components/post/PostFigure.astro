---
/*
 * PostFigure — the figure primitive for long-form posts.
 *
 * Replaces hand-written <figure> HTML in Markdown, which had two failure modes:
 * the markup was duplicated per figure, and `remark-math` never visits raw HTML
 * blocks, so math in a caption silently rendered its own source. The caption is
 * a slot, so <Math> (or any component) works inside it.
 *
 * Layout comes from src/styles/editorial.css:
 *   variant="wide" → breaks out to the full column
 *   variant="side" → floats into the margin field; prose runs alongside
 */
import { slugify } from "../../lib/slug";
import { getFigure, figureSrc } from "../../lib/figures";

interface Props {
  /*
   * Figure id — path, alt text, dimensions and credit resolve from
   * src/data/figures.json, the only place a figure is described. The CAPTION
   * stays a slot: post captions are MDX with markup and inline math, and
   * cannot live in JSON without ceasing to be MDX.
   */
  id: string;
  variant?: "wide" | "side";
  eager?: boolean;
}

const { id: figureId, variant, eager } = Astro.props;
const f = getFigure(figureId);
const { alt, width, height, credit } = f;
const src = figureSrc(f);
const cls = ["figure", variant && `fig-${variant}`].filter(Boolean).join(" ");
const id = `fig-${slugify(src.split("/").pop() ?? "figure")}`;
---

<figure class={cls} id={id}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={eager ? "eager" : "lazy"}
    decoding="async"
  />
  <figcaption>
    <slot />
    {credit && <span class="fig-credit">{credit}</span>}
  </figcaption>
</figure>
