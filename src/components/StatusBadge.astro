---
/*
 * StatusBadge — honest development-status pill for a package. Colors follow
 * Anna's Cosmic Playground status system: teal = established, rose = active
 * build (draft), violet = planned.
 */
import { STATUS_LABEL, type PackageStatus } from "../data/jaxstro";

interface Props {
  status: PackageStatus;
}
const { status } = Astro.props;
---

<span class={`badge badge--${status}`}>{STATUS_LABEL[status]}</span>

<style>
  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    border: 1px solid;
    white-space: nowrap;
  }
  .badge--established {
    color: var(--spec-teal-bright);
    border-color: color-mix(in srgb, var(--spec-teal) 45%, transparent);
    background: color-mix(in srgb, var(--spec-teal) 15%, transparent);
  }
  .badge--active-build {
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border-color: color-mix(in srgb, var(--spec-rose) 45%, transparent);
    background: color-mix(in srgb, var(--spec-rose) 16%, transparent);
  }
  .badge--planned {
    color: color-mix(in srgb, var(--spec-violet) 88%, white);
    border-color: color-mix(in srgb, var(--spec-violet) 48%, transparent);
    background: color-mix(in srgb, var(--spec-violet) 14%, transparent);
  }
</style>
