---
/*
 * JaxstroEcosystem — the signature software visualization.
 *
 * A differentiable birth-to-observation pipeline sitting on the shared jaxstro
 * foundation. Built from typed data (data/jaxstro.ts), not hard-coded nodes.
 *
 * Accessibility: the pipeline is a real ordered list; every node is a link to
 * its detailed card below (so no information is hover-only). Connectors are
 * decorative (aria-hidden). Works with no JavaScript; reduced-motion safe.
 */
import { pipeline, foundation } from "../data/jaxstro";
import StatusBadge from "./StatusBadge.astro";
---

<figure class="eco">
  <ol class="eco__pipeline" role="list">
    {
      pipeline.map((pkg) => (
        <li class="eco__node">
          <a class="eco__node-link" href={`#pkg-${pkg.name}`}>
            <span class="eco__stage">{pkg.stage}</span>
            <span class="eco__name">{pkg.name}</span>
            <StatusBadge status={pkg.status} />
            {pkg.maturity && <span class="eco__maturity">{pkg.maturity}</span>}
          </a>
        </li>
      ))
    }
  </ol>

  <p class="eco__return" aria-hidden="true">
    ← gradients &amp; observing-design information flow back
  </p>

  <a class="eco__foundation" href={`#pkg-${foundation.name}`}>
    <span class="eco__stage">{foundation.stage}</span>
    <span class="eco__name">{foundation.name}</span>
    <span class="eco__foundation-tag">{foundation.tagline}</span>
    {foundation.maturity && <span class="eco__maturity">{foundation.maturity}</span>}
    <StatusBadge status={foundation.status} />
  </a>

  <figcaption class="eco__caption">
    The <code>jaxstro</code> ecosystem: a differentiable model from a cluster's
    birth to its survey observables, returning the gradients that reveal what
    the data can recover. Select any stage for detail.
  </figcaption>
</figure>

<style>
  .eco {
    margin: 0;
  }

  .eco__pipeline {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-2xs);
    align-items: stretch;
  }

  .eco__node {
    position: relative;
    display: flex;
  }

  /* Decorative connector arrow between nodes */
  .eco__node + .eco__node::before {
    content: "→";
    position: absolute;
    inset-inline-start: calc(var(--space-2xs) * -1);
    inset-block-start: 50%;
    transform: translate(-40%, -50%);
    color: var(--spec-teal);
    font-size: var(--step-0);
    pointer-events: none;
  }

  .eco__node-link,
  .eco__foundation {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    inline-size: 100%;
    padding: var(--space-s);
    text-decoration: none;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    transition:
      border-color var(--dur-base) var(--ease-out),
      background-color var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }
  .eco__node-link:hover,
  .eco__node-link:focus-visible,
  .eco__foundation:hover,
  .eco__foundation:focus-visible {
    border-color: color-mix(in srgb, var(--spec-teal) 45%, var(--border));
    background: color-mix(in srgb, var(--spec-teal) 8%, var(--bg-deep));
    transform: translateY(-2px);
  }

  .eco__stage {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .eco__name {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--spec-teal-bright);
  }
  .eco__maturity {
    font-size: 0.7rem;
    color: var(--ink-dim);
  }

  .eco__return {
    margin-block: var(--space-s) var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-faint);
    text-align: center;
  }

  .eco__foundation {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    border-style: dashed;
    border-color: color-mix(in srgb, var(--spec-teal) 30%, var(--border));
    background: color-mix(in srgb, var(--spec-teal) 6%, var(--bg-deep));
  }
  .eco__foundation .eco__name {
    font-size: var(--step-2);
  }
  .eco__foundation-tag {
    color: var(--ink-soft);
    margin-inline-end: auto;
  }

  .eco__caption {
    margin-block-start: var(--space-m);
    max-inline-size: var(--width-prose);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }
  .eco__caption code {
    font-family: var(--font-mono);
    color: var(--spec-teal-bright);
  }

  /* ── Narrow screens: stack the pipeline vertically ─────────────── */
  @media (max-width: 52rem) {
    .eco__pipeline {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }
    .eco__node + .eco__node::before {
      content: "↓";
      inset-inline-start: 50%;
      inset-block-start: calc(var(--space-m) * -1);
      transform: translate(-50%, -30%);
    }
  }
</style>
