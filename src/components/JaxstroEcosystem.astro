---
/*
 * JaxstroEcosystem — the signature software visualization.
 *
 * The differentiable birth-to-observation pipeline. Shows the five STAGES only:
 * the jaxstro foundation used to repeat here as a card, but it is now row 00 of
 * the list below, so a second copy was pure duplication. Built from the
 * `packages` content collection, not hard-coded nodes.
 *
 * Accessibility: the pipeline is a real ordered list; every node is a link to
 * its detailed card below (so no information is hover-only). Connectors are
 * decorative (aria-hidden). Works with no JavaScript; reduced-motion safe.
 */
import { getPipeline } from "../lib/packages";

const { stages: pipeline } = await getPipeline();
if (pipeline.length === 0) {
  // In a build this means real data trouble. In dev it nearly always means the
  // server was started before src/content.config.ts declared this collection,
  // so its content store never learned about it — restart, do not debug.
  throw new Error(
    "packages collection is empty. If the dev server was running when the " +
      "collection was added, restart it: `astro dev stop && astro dev --background`.",
  );
}
import StatusBadge from "./StatusBadge.astro";
---

<figure class="eco">
  <ol class="eco__pipeline" role="list">
    {
      pipeline.map((pkg) => (
        <li class="eco__node">
          <a class="eco__node-link" href={`/software/${pkg.id}`}>
            <span class="eco__stage">{pkg.data.stage}</span>
            <span class="eco__name">{pkg.data.name}</span>
            <StatusBadge status={pkg.data.status} />
            {pkg.data.maturity && <span class="eco__maturity">{pkg.data.maturity}</span>}
          </a>
        </li>
      ))
    }
  </ol>

  <p class="eco__return" aria-hidden="true">
    ← gradients &amp; observing-design information flow back
  </p>

  <figcaption class="eco__caption">
    The Jaxstro ecosystem: a differentiable model from a cluster's birth to its
    survey observables, returning the gradients that reveal what the data can
    recover. Every stage composes on the shared <code>jaxstro</code> foundation.
    Select any stage for detail.
  </figcaption>
</figure>

<style>
  .eco {
    margin: 0;
  }

  .eco__pipeline {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-2xs);
    align-items: stretch;
  }

  .eco__node {
    position: relative;
    display: flex;
  }

  /* Decorative connector arrow between nodes */
  .eco__node + .eco__node::before {
    content: "→";
    position: absolute;
    inset-inline-start: calc(var(--space-2xs) * -1);
    inset-block-start: 50%;
    transform: translate(-40%, -50%);
    color: var(--spec-teal);
    font-size: var(--step-0);
    pointer-events: none;
  }

  .eco__node-link,
  .eco__node-link:hover,
  .eco__node-link:focus-visible,

  .eco__stage {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .eco__name {
    font-family: var(--font-mono);
    font-size: var(--step-1);
    color: var(--spec-teal-bright);
  }
  .eco__maturity {
    font-size: 0.7rem;
    color: var(--ink-dim);
  }

  .eco__return {
    margin-block: var(--space-s) var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-faint);
    text-align: center;
  }


  .eco__caption {
    margin-block-start: var(--space-m);
    max-inline-size: var(--width-prose);
    color: var(--ink-dim);
    font-size: var(--step--1);
  }
  .eco__caption code {
    font-family: var(--font-mono);
    color: var(--spec-teal-bright);
  }

  /* ── Narrow screens: stack the pipeline vertically ─────────────── */
  @media (max-width: 52rem) {
    .eco__pipeline {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }
    .eco__node + .eco__node::before {
      content: "↓";
      inset-inline-start: 50%;
      inset-block-start: calc(var(--space-m) * -1);
      transform: translate(-50%, -30%);
    }
  }
</style>
