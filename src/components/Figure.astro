---
/*
 * Figure — accessible scientific figure with caption, credit, and an optional
 * "preliminary" flag for unpublished/in-prep work. Requires explicit width/
 * height to reserve space (no layout shift); lazy-loads below the fold.
 */
import { getFigure, figureSrc, figureCaption, figureBox } from "../lib/figures";
import { renderCaption } from "../lib/figureCaption";

/*
 * A figure is REFERENCED by id. Path, alt text, dimensions, credit and caption
 * all resolve from src/data/figures.json, which is the only place a figure is
 * described. Props here are layout and caption choice, nothing else — when
 * every page carried its own copy of the description they could disagree, and
 * once they did.
 */
interface Props {
  /** Figure id — the filename without its extension. */
  id: string;
  /** Which recorded caption to show. Pages showing a figure in passing want "short". */
  caption?: "full" | "short";
  /** Constrain very tall images to a sensible max height. */
  contain?: boolean;
  /**
   * Set the figure beside its caption instead of above it: caption left,
   * image right. For tall portraits, where a full-width image pushes the
   * argument off the screen and buries the point it is evidence for.
   */
  side?: boolean;
  /**
   * Float the figure into the text so prose runs alongside it. "end" is the
   * usual choice; "start" when something else already occupies the right.
   * Only meaningful inside a prose column — see figures.css.
   */
  inline?: "end" | "start";
}
const { id, caption = "full", contain, side, inline } = Astro.props;
const f = getFigure(id);
const { alt, width, height, credit, preliminary } = f;
const captionText = figureCaption(f, caption);
---

<figure
  class:list={[
    "fig",
    { "fig--side": side },
    inline && "figure-inline",
    inline === "start" && "figure-inline--start",
  ]}
>
  <div class:list={["fig__frame", { "fig__frame--contain": contain }]}>
    <img
      class="figure-box"
      style={figureBox(f)}
      src={figureSrc(f)}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
    />
    {/* Overlay only at full width. Shrunk into the side column the badge spans
        65% of the image and buries the top-row panel headers, so there it moves
        into the caption as a chip — the same marker the package pages use. */}
    {preliminary && !side && <span class="fig__flag">Preliminary · in&nbsp;prep</span>}
  </div>
  <figcaption class="fig__cap">
    {/* Explicit space: Astro collapses whitespace before an inline element at a
        line break, which runs the chip into the caption ("in prepThis is…"). */}
    {preliminary && side && <span class="fig__chip">Preliminary · in&nbsp;prep</span>}{" "}
    <span set:html={renderCaption(captionText)} />
    {credit && <span class="fig__credit">{credit}</span>}
  </figcaption>
</figure>

<style>
  .fig {
    margin: 0;
  }
  .fig__frame {
    position: relative;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    overflow: hidden;
  }
  .fig__frame img {
    inline-size: 100%;
    block-size: auto;
  }
  /* A figure that dwarfs the prose it supports inverts the hierarchy: the
     argument is the text, the figure is evidence for it. Capped near the
     reading measure rather than filling the column. */
  .fig {
    max-inline-size: min(100%, 48rem);
  }
  /* Side layout: the argument reads on the left, the evidence sits beside it.
     Grid placement rather than source reordering, so the DOM keeps figure
     before caption. Below the breakpoint it falls back to the stacked default,
     where a two-column split would leave both halves too narrow to read. */
  @media (min-width: 52rem) {
    .fig--side {
      max-inline-size: 100%;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 21rem);
      gap: var(--space-l);
      align-items: start;
    }
    .fig--side .fig__frame {
      grid-column: 2;
      grid-row: 1;
    }
    .fig--side .fig__cap {
      grid-column: 1;
      grid-row: 1;
      margin-block-start: 0;
      /* The caption is the argument here, so it keeps a reading measure
         instead of stretching to whatever the column leaves over. */
      max-inline-size: var(--width-prose);
    }
  }

  .fig__frame--contain img {
    max-block-size: 32rem;
    inline-size: auto;
    max-inline-size: 100%;
    margin-inline: auto;
  }
  .fig__flag {
    position: absolute;
    inset-block-start: var(--space-2xs);
    inset-inline-end: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--spec-rose) 85%, white);
    background: color-mix(in srgb, var(--bg-void) 78%, transparent);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 2px 8px;
    backdrop-filter: blur(4px);
  }
  .fig__chip {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: color-mix(in srgb, var(--spec-rose) 82%, white);
    border: 1px solid color-mix(in srgb, var(--spec-rose) 45%, transparent);
    border-radius: 999px;
    padding: 1px 7px;
    margin-inline-end: var(--space-2xs);
    vertical-align: 1px;
    display: inline-block;
  }
  .fig__cap {
    margin-block-start: var(--space-s);
    /* Was --step--1 (15px against 19px body) and ran the full figure width.
       A caption is read, not skimmed: it gets a real size and a real measure. */
    font-size: var(--step-0);
    color: var(--ink-soft);
    line-height: 1.6;
  }
  .fig__credit {
    display: block;
    margin-block-start: var(--space-3xs);
    color: var(--ink-faint);
    font-style: italic;
  }
</style>
