---
/*
 * ReadinessMeter — how far along a piece of software is, shown rather than
 * buried in prose. A thin wrapper over the shared Meter primitive so the
 * readiness bar and the paper-progress bar are visually identical.
 *
 * Also used on /teaching, so status reads the same everywhere.
 */
import Meter from "./Meter.astro";
import { READINESS_LABEL, READINESS_STEPS, READINESS_TOTAL, type Readiness } from "../data/jaxstro";

interface Props {
  readiness: Readiness;
  /** Free-text maturity note for the tooltip, e.g. "Mature · methods paper in prep". */
  title?: string;
}
const { readiness, title } = Astro.props;
---

<Meter
  on={READINESS_STEPS[readiness]}
  total={READINESS_TOTAL}
  label={READINESS_LABEL[readiness]}
  ariaLabel={`Readiness: ${READINESS_LABEL[readiness]}`}
  title={title}
/>
