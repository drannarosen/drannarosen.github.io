---
/*
 * ReleaseTrack — how close a package is to being usable by someone else.
 *
 * Deliberately separate from ReadinessMeter. Readiness is how far the software
 * has come; this is whether anyone can have it. Every package sat at "mature"
 * or "advanced" with no repository, and nothing on the page explained why —
 * which reads as vapour rather than as a hold pending publication.
 *
 * Renders nothing when there is no track to report, so a package that has not
 * declared one is unaffected.
 */
import {
  PAPER_STATE_LABEL,
  CODE_RELEASE_LABEL,
  type PaperState,
  type CodeRelease,
} from "../data/jaxstro";

interface Props {
  papers?: { methods?: PaperState; software?: PaperState };
  codeRelease?: CodeRelease;
  /** Compact form for the index list; the package page uses the full one. */
  compact?: boolean;
}

const { papers, codeRelease = "with-paper", compact } = Astro.props;

const items: { label: string; state: string; soon: boolean }[] = [];
if (papers?.methods) {
  items.push({
    label: "Methods paper",
    state: PAPER_STATE_LABEL[papers.methods],
    soon: papers.methods !== "planned",
  });
}
if (papers?.software) {
  items.push({
    label: "Software paper",
    state: PAPER_STATE_LABEL[papers.software],
    soon: papers.software !== "planned",
  });
}
---

{
  items.length > 0 && (
    <p class:list={["track", compact && "track--compact"]}>
      {items.map((item, i) => (
        <>
          {i > 0 && <span class="track__sep"> · </span>}
          <span class:list={["track__item", item.soon && "is-soon"]}>
            {item.label} <span class="track__state">{item.state}</span>
          </span>
        </>
      ))}
      {!compact && (
        <>
          <span class="track__sep"> · </span>
          <span class="track__item">{CODE_RELEASE_LABEL[codeRelease]}</span>
        </>
      )}
    </p>
  )
}

<style>
  .track {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-faint);
  }
  .track--compact {
    margin-block-start: var(--space-3xs);
  }
  .track__state {
    color: var(--ink-dim);
  }
  /* A paper actually being written is the part worth noticing; "planned" is
     not news and should not compete with it. */
  .track__item.is-soon .track__state {
    color: var(--spec-teal-bright);
  }
</style>
