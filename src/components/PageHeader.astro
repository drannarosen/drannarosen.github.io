---
/*
 * PageHeader — consistent title block for interior pages. Keeps the H1 and
 * intent statement styled identically site-wide.
 */
/*
 * `title` and `lede` accept either a plain string prop or a named slot. Use the
 * slot when the text needs rich content — e.g. <Math> for LaTeX:
 *
 *   <PageHeader title="Mass segregation">
 *     <Fragment slot="lede">One knob, <Math tex="\lcorr" />, sets …</Fragment>
 *   </PageHeader>
 *
 * A slot wins over the matching prop when both are supplied.
 */
/*
 * An optional `aside` slot puts supporting media level with the title, in a
 * right-hand column, instead of below the header. The default slot adds further
 * prose to the left column so it shares the aside's height. Without an `aside`
 * the header is unchanged, so every existing page is untouched.
 */
interface Props {
  eyebrow?: string;
  /** Optional when a `title` slot is provided instead. */
  title?: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
const hasTitleSlot = Astro.slots.has("title");
const hasLedeSlot = Astro.slots.has("lede");
const hasAside = Astro.slots.has("aside");
---

<header class:list={["page-header wrap", { "page-header--split": hasAside }]}>
  {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
  <div class="page-header__main">
    <h1 class="page-header__title">
      {hasTitleSlot ? <slot name="title" /> : title}
    </h1>
    {
      (hasLedeSlot || lede) && (
        <p class="page-header__lede prose">
          {hasLedeSlot ? <slot name="lede" /> : lede}
        </p>
      )
    }
    <slot />
  </div>
  {hasAside && <div class="page-header__aside"><slot name="aside" /></div>}
</header>

<style>
  .page-header {
    padding-block: var(--space-2xl) var(--space-l);
  }
  .page-header__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--spec-cyan);
    margin-block-end: var(--space-s);
  }
  .page-header__title {
    font-size: var(--step-4);
  }
  .page-header__lede {
    font-size: var(--step-1);
    color: var(--ink-soft);
    margin-block-start: var(--space-s);
  }

  /* Split header: supporting media sits level with the title rather than under
     the whole block. Below the breakpoint it stacks, where two columns would
     leave the text column too narrow to read. */
  @media (min-width: 60rem) {
    .page-header--split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, var(--page-header-aside, 20rem));
      column-gap: var(--space-xl);
      /* No row-gap: the eyebrow sits on its own row and already carries a
         margin. A gap here would also open a space above the title on any
         split header without an eyebrow. */
      row-gap: 0;
      align-items: start;
    }
    /* The eyebrow takes row 1 alone so the aside starts level with the TITLE
       rather than with the eyebrow above it. Explicit placement rather than a
       hardcoded top offset, which would drift with the eyebrow's type scale. */
    .page-header--split > .page-header__eyebrow {
      grid-column: 1;
      grid-row: 1;
    }
    .page-header--split > .page-header__main {
      grid-column: 1;
      grid-row: 2;
    }
    .page-header--split > .page-header__aside {
      grid-column: 2;
      grid-row: 2;
    }
  }
  .page-header__aside {
    margin-block-start: var(--space-m);
  }
  @media (min-width: 60rem) {
    .page-header__aside {
      margin-block-start: 0;
    }
  }
</style>
