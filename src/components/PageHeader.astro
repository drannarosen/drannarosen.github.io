---
/*
 * PageHeader — consistent title block for interior pages. Keeps the H1 and
 * intent statement styled identically site-wide.
 */
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<header class="page-header wrap">
  {eyebrow && <p class="page-header__eyebrow">{eyebrow}</p>}
  <h1 class="page-header__title">{title}</h1>
  {lede && <p class="page-header__lede prose">{lede}</p>}
</header>

<style>
  .page-header {
    padding-block: var(--space-2xl) var(--space-l);
  }
  .page-header__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--spec-cyan);
    margin-block-end: var(--space-s);
  }
  .page-header__title {
    font-size: var(--step-4);
  }
  .page-header__lede {
    font-size: var(--step-1);
    color: var(--ink-soft);
    margin-block-start: var(--space-s);
  }
</style>
