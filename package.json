{
  "name": "drannarosen-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "sync:pubs": "node scripts/publications/sync_orcid.mjs",
    "sync:pubs:check": "node scripts/publications/sync_orcid.mjs --check",
    "check:figures": "node scripts/figures/check.mjs",
    "og": "node scripts/og/generate.mjs",
    "prebuild": "node --experimental-strip-types scripts/check-sun.mjs && node --experimental-strip-types scripts/check-stellar.mjs && node --experimental-strip-types scripts/check-cluster.mjs && node scripts/check-novascope-boundary.mjs && node scripts/check-type.mjs && node scripts/figures/check.mjs && node scripts/cv/check.mjs --check && node scripts/og/generate.mjs",
    "check:type": "node scripts/check-type.mjs",
    "cv:pdf": "typst compile --root . cv/cv_rosen.typ public/documents/cv-anna-rosen.pdf",
    "check:links": "node scripts/check-links.mjs",
    "check:links:external": "node scripts/check-links.mjs --external",
    "check:markup": "node scripts/check-markup.mjs",
    "check:cv": "node scripts/cv/check.mjs",
    "check:stellar": "node --experimental-strip-types scripts/check-stellar.mjs",
    "check:novascope": "node scripts/check-novascope-boundary.mjs",
    "check:cluster": "node --experimental-strip-types scripts/check-cluster.mjs",
    "search:index": "node scripts/search/build-index.mjs",
    "check:sun": "node --experimental-strip-types scripts/check-sun.mjs",
    "postbuild": "node scripts/search/build-index.mjs && node scripts/check-links.mjs && node scripts/check-markup.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.1",
    "katex": "^0.18.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/katex": "^0.16.8",
    "sharp": "^0.35.3",
    "typescript": "^5.9.3"
  }
}
